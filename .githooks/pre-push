#!/usr/bin/env bash
set -euo pipefail

# Spine pre-push hook (versioned)
#
# Lightweight guard: pushing to main requires OPS_GOVERNED_MAIN_OVERRIDE=1.
# This prevents accidental agent pushes to main while keeping the coordinator
# workflow frictionless (single env var, no ceremony).
#
# Multi-agent coordinator metadata (7 env vars) removed — governance ceremony
# overhead reduction. See: LOOP-session-git-workflow-simplification

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[[ -n "${ROOT:-}" ]] || exit 0
cd "$ROOT"

REMOTE_NAME="${1:-unknown-remote}"
REMOTE_URL="${2:-unknown-url}"

targets_main=0
while IFS=' ' read -r _local_ref _local_sha remote_ref _remote_sha; do
  [[ -n "${remote_ref:-}" ]] || continue
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    targets_main=1
    break
  fi
done

[[ "$targets_main" -eq 1 ]] || exit 0

# Single-var governed override — same pattern as pre-commit Guard 0.
OVERRIDE="${OPS_GOVERNED_MAIN_OVERRIDE:-}"
OVERRIDE_LC="$(printf '%s' "$OVERRIDE" | tr '[:upper:]' '[:lower:]')"

if [[ "$OVERRIDE_LC" == "1" || "$OVERRIDE_LC" == "true" || "$OVERRIDE_LC" == "yes" ]]; then
  echo "NOTICE: governed push to main allowed (remote=$REMOTE_NAME)." >&2
  exit 0
fi

echo "BLOCKED: push to 'main' requires governed override." >&2
echo "remote: $REMOTE_NAME ($REMOTE_URL)" >&2
echo "" >&2
echo "Remediation:" >&2
echo "  OPS_GOVERNED_MAIN_OVERRIDE=1 git push $REMOTE_NAME main" >&2
exit 1
