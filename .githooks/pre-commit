#!/usr/bin/env bash
set -euo pipefail

# Spine pre-commit hook (versioned)
#
# Guards:
# 0. Main branch protection (OPS_GOVERNED_MAIN_OVERRIDE=1 to commit on main)
# 5. Hook-fast AOF hygiene checks (staged only)
# 6. Gate registry projection autopilot (gate.registry.yaml staged)
#
# Guards 1-4,7-8 removed — governance ceremony overhead reduction.
# Guard 0 simplified to single-var override (matching pre-push).
# See: LOOP-session-git-workflow-simplification

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${ROOT:-}" ]]; then
  exit 0
fi

cd "$ROOT"

if ! command -v git >/dev/null 2>&1; then
  exit 0
fi

current_branch="$(git branch --show-current 2>/dev/null || echo detached)"

staged="$(git diff --cached --name-only --diff-filter=ACMRT 2>/dev/null || true)"

# ─── Guard 0: Main branch protection ──────────────────────
# Single-var governed override — prevents accidental main commits from agents.
# Same pattern as pre-push hook: OPS_GOVERNED_MAIN_OVERRIDE=1 to proceed.
if [[ -n "${staged:-}" && ("$current_branch" == "main" || "$current_branch" == "master") ]]; then
  OVERRIDE="${OPS_GOVERNED_MAIN_OVERRIDE:-}"
  OVERRIDE_LC="$(printf '%s' "$OVERRIDE" | tr '[:upper:]' '[:lower:]')"

  if [[ "$OVERRIDE_LC" == "1" || "$OVERRIDE_LC" == "true" || "$OVERRIDE_LC" == "yes" ]]; then
    echo "NOTICE: main commit override accepted." >&2
  else
    echo "BLOCKED: direct commits on '$current_branch' are fail-closed by default." >&2
    echo "" >&2
    echo "Remediation:" >&2
    echo "  OPS_GOVERNED_MAIN_OVERRIDE=1 git commit ..." >&2
    exit 1
  fi
fi

# ─── Guard 5: Hook-fast AOF hygiene checks (staged only) ───
# Keep pre-commit lightweight while catching common AOF drift early.

if echo "$staged" | rg -q '^ops/bindings/.*\.ya?ml$'; then
  schema_audit="ops/plugins/verify/bin/schema-conventions-audit"
  if [[ ! -x "$schema_audit" ]]; then
    echo "STOP: missing schema audit runner: $schema_audit" >&2
    exit 1
  fi
  "$schema_audit" --mode staged
fi

if echo "$staged" | rg -q '^(mailroom/state/loop-scopes/.*\.scope\.md|docs/product/.*\.md)$'; then
  d145_gate="surfaces/verify/d145-aof-decomposition-vocabulary-lock.sh"
  if [[ ! -x "$d145_gate" ]]; then
    echo "STOP: missing decomposition vocabulary gate: $d145_gate" >&2
    exit 1
  fi
  "$d145_gate" --staged-only
fi

# ─── Guard 6: Gate registry projection autopilot ────────────
# When gate.registry.yaml is staged, reconcile header metadata and
# re-sync entry-surface projections so D85/D285 stay green.

if echo "$staged" | grep -qx 'ops/bindings/gate.registry.yaml'; then
  gen_header="$ROOT/bin/generators/gen-gate-registry-header.sh"
  if [[ -x "$gen_header" ]]; then
    "$gen_header" || {
      echo "STOP: gen-gate-registry-header.sh failed" >&2
      exit 1
    }
    git add ops/bindings/gate.registry.yaml
  fi

  projection_allowlist_file="$ROOT/ops/bindings/projection.reconcile.allowlist.txt"
  projection_allowlist=()
  if [[ -f "$projection_allowlist_file" ]]; then
    while IFS= read -r allow_path; do
      [[ -n "$allow_path" ]] || continue
      [[ "$allow_path" =~ ^# ]] && continue
      projection_allowlist+=("$allow_path")
    done < "$projection_allowlist_file"
  fi
  if [[ "${#projection_allowlist[@]}" -eq 0 ]]; then
    projection_allowlist=(
      "ops/bindings/gate.registry.yaml"
      "AGENTS.md"
      "CLAUDE.md"
      "docs/governance/generated/ENTRY_SURFACE_GATE_METADATA.md"
      "docs/governance/generated/BOOT_ENTRY_SURFACE.md"
    )
  fi

  # Run projection sync without capability/role policy friction in git hooks.
  projection_sync_ok=0
  if [[ -x "$ROOT/ops/plugins/docs/bin/docs-projection-sync" ]]; then
    if "$ROOT/ops/plugins/docs/bin/docs-projection-sync" >/dev/null 2>&1; then
      projection_sync_ok=1
    fi
  fi
  if [[ "$projection_sync_ok" -eq 0 ]]; then
    gen_entry="$ROOT/bin/generators/gen-entry-surface-gate-metadata.sh"
    gen_boot="$ROOT/bin/generators/gen-boot-entry-surface.sh"
    if [[ -x "$gen_entry" && -x "$gen_boot" ]] \
      && "$gen_entry" --write-surfaces >/dev/null 2>&1 \
      && "$gen_boot" --write-surfaces >/dev/null 2>&1; then
      projection_sync_ok=1
    fi
  fi
  if [[ "$projection_sync_ok" -eq 0 ]]; then
    echo "STOP: docs projection sync failed." >&2
    echo "Remediation: run ./ops/plugins/docs/bin/docs-projection-sync and stage projection files." >&2
    exit 1
  fi

  # Deterministic auto-restage for all projection-authority files.
  for f in "${projection_allowlist[@]}"; do
    [[ -f "$ROOT/$f" ]] && git add "$f"
  done
fi
