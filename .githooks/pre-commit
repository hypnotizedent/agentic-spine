#!/usr/bin/env bash
set -euo pipefail

# Spine pre-commit hook (versioned)
#
# Guards:
# 0. Hard-default branch/worktree governance (main blocked by default, non-main isolation required)
# 5. Hook-fast AOF hygiene checks (staged only)
# 6. Gate registry projection autopilot (gate.registry.yaml staged)
#
# Guards 1-4,7-8 removed — governance ceremony overhead reduction.
# See: LOOP-session-git-workflow-simplification

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${ROOT:-}" ]]; then
  exit 0
fi

cd "$ROOT"

if ! command -v git >/dev/null 2>&1; then
  exit 0
fi

current_branch="$(git branch --show-current 2>/dev/null || echo detached)"

staged="$(git diff --cached --name-only --diff-filter=ACMRT 2>/dev/null || true)"

# ─── Guard 0: Hard-default branch/worktree governance ──────
# MARKER: hard-default-main-commit-guard
# MARKER: hard-default-worktree-identity-guard
# Mainline commits are blocked unless an explicit governed override token with
# reference+reason is present. Non-main commits require D140 worktree identity.
if [[ -n "${staged:-}" ]]; then
  MAIN_OVERRIDE_TOKEN="${OPS_GOVERNED_MAIN_OVERRIDE:-}"
  MAIN_OVERRIDE_REF="${OPS_GOVERNED_MAIN_OVERRIDE_REF:-}"
  MAIN_OVERRIDE_REASON="${OPS_GOVERNED_MAIN_OVERRIDE_REASON:-}"
  MAIN_OVERRIDE_TOKEN_LC="$(printf '%s' "$MAIN_OVERRIDE_TOKEN" | tr '[:upper:]' '[:lower:]')"
  WORKTREE_STATUS_SCRIPT="$ROOT/ops/plugins/ops/bin/worktree-session-status"

  if [[ "$current_branch" == "main" || "$current_branch" == "master" ]]; then
    if [[ "$MAIN_OVERRIDE_TOKEN_LC" == "1" || "$MAIN_OVERRIDE_TOKEN_LC" == "true" || "$MAIN_OVERRIDE_TOKEN_LC" == "yes" ]]; then
      if [[ -z "$MAIN_OVERRIDE_REF" || -z "$MAIN_OVERRIDE_REASON" ]]; then
        echo "BLOCKED: governed main override token requires ref + reason." >&2
        echo "" >&2
        echo "Coordinator override syntax:" >&2
        echo "  OPS_GOVERNED_MAIN_OVERRIDE=1 OPS_GOVERNED_MAIN_OVERRIDE_REF=<LOOP|WAVE|INCIDENT> OPS_GOVERNED_MAIN_OVERRIDE_REASON=\"<justification>\" git commit ..." >&2
        exit 1
      fi
      echo "NOTICE: main commit override accepted (ref=$MAIN_OVERRIDE_REF)." >&2
    else
      echo "BLOCKED: direct commits on '$current_branch' are fail-closed by default." >&2
      echo "" >&2
      echo "Remediation:" >&2
      echo "  1. Start an isolated lane/worktree: ./bin/ops wave start <WAVE_ID> --objective \"...\"" >&2
      echo "  2. Rehydrate existing branch into managed worktree: ./bin/ops cap run worktree.lifecycle.rehydrate -- --branch <branch> --lane <lane>" >&2
      echo "  3. Coordinator override (exception path): OPS_GOVERNED_MAIN_OVERRIDE=1 OPS_GOVERNED_MAIN_OVERRIDE_REF=<ref> OPS_GOVERNED_MAIN_OVERRIDE_REASON=\"<reason>\" git commit ..." >&2
      exit 1
    fi
  else
    if [[ ! -x "$WORKTREE_STATUS_SCRIPT" ]]; then
      echo "BLOCKED: missing worktree isolation checker: $WORKTREE_STATUS_SCRIPT" >&2
      exit 1
    fi
    if ! wt_out="$("$WORKTREE_STATUS_SCRIPT" --enforce --brief 2>&1)"; then
      echo "BLOCKED: non-main commits require isolated worktree identity." >&2
      echo "Guard output: $wt_out" >&2
      echo "" >&2
      echo "Remediation:" >&2
      echo "  1. Kick off governed lanes: ./bin/ops cap run orchestration.wave.kickoff -- --loop-id <LOOP_ID> --lanes A,B,C" >&2
      echo "  2. Export identity: export OPS_WORKTREE_IDENTITY=<LOOP_ID|WAVE_ID>" >&2
      echo "  3. If branch path is unmanaged: ./bin/ops cap run worktree.lifecycle.rehydrate -- --branch $current_branch --lane <lane>" >&2
      exit 1
    fi
  fi
fi

# ─── Guard 5: Hook-fast AOF hygiene checks (staged only) ───
# Keep pre-commit lightweight while catching common AOF drift early.

if echo "$staged" | rg -q '^ops/bindings/.*\.ya?ml$'; then
  schema_audit="ops/plugins/verify/bin/schema-conventions-audit"
  if [[ ! -x "$schema_audit" ]]; then
    echo "STOP: missing schema audit runner: $schema_audit" >&2
    exit 1
  fi
  "$schema_audit" --mode staged
fi

if echo "$staged" | rg -q '^(mailroom/state/loop-scopes/.*\.scope\.md|docs/product/.*\.md)$'; then
  d145_gate="surfaces/verify/d145-aof-decomposition-vocabulary-lock.sh"
  if [[ ! -x "$d145_gate" ]]; then
    echo "STOP: missing decomposition vocabulary gate: $d145_gate" >&2
    exit 1
  fi
  "$d145_gate" --staged-only
fi

# ─── Guard 6: Gate registry projection autopilot ────────────
# When gate.registry.yaml is staged, reconcile header metadata and
# re-sync entry-surface projections so D85/D285 stay green.

if echo "$staged" | grep -qx 'ops/bindings/gate.registry.yaml'; then
  gen_header="$ROOT/bin/generators/gen-gate-registry-header.sh"
  if [[ -x "$gen_header" ]]; then
    "$gen_header" || {
      echo "STOP: gen-gate-registry-header.sh failed" >&2
      exit 1
    }
    git add ops/bindings/gate.registry.yaml
  fi

  if [[ -x "$ROOT/ops/plugins/docs/bin/docs-projection-sync" ]]; then
    projection_allowlist_file="$ROOT/ops/bindings/projection.reconcile.allowlist.txt"
    projection_allowlist=()
    if [[ -f "$projection_allowlist_file" ]]; then
      while IFS= read -r allow_path; do
        [[ -n "$allow_path" ]] || continue
        [[ "$allow_path" =~ ^# ]] && continue
        projection_allowlist+=("$allow_path")
      done < "$projection_allowlist_file"
    fi
    if [[ "${#projection_allowlist[@]}" -eq 0 ]]; then
      projection_allowlist=(
        "ops/bindings/gate.registry.yaml"
        "AGENTS.md"
        "CLAUDE.md"
        "docs/governance/generated/ENTRY_SURFACE_GATE_METADATA.md"
        "docs/governance/generated/BOOT_ENTRY_SURFACE.md"
      )
    fi

    "$ROOT/bin/ops" cap run docs.projection.sync >/dev/null 2>&1 || {
      echo "STOP: docs.projection.sync failed." >&2
      echo "Remediation: ./bin/ops cap run docs.projection.sync && git add \$(cat ops/bindings/projection.reconcile.allowlist.txt | rg -v '^#|^$')" >&2
      exit 1
    }

    # Deterministic auto-restage for all projection-authority files.
    for f in "${projection_allowlist[@]}"; do
      [[ -f "$ROOT/$f" ]] && git add "$f"
    done
  fi
fi
