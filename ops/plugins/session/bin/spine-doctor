#!/usr/bin/env bash
# spine.doctor - read-only runtime bootstrap diagnostics and portability preflight.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)"
BOOTSTRAP_CONTRACT="$ROOT/ops/bindings/runtime.bootstrap.contract.yaml"
PATH_BASELINE="$ROOT/ops/bindings/runtime.path.inventory.baseline.yaml"
TENANT_PROFILE="$ROOT/ops/bindings/tenant.profile.yaml"
TENANT_SCHEMA="$ROOT/ops/bindings/tenant.profile.schema.yaml"
ENV_FILE="$ROOT/.environment.yaml"
IDENTITY_FILE="$ROOT/.identity.yaml"

VERIFY_FAST=0
STRICT=0
JSON_MODE=0

usage() {
  cat <<'EOF'
Usage:
  spine-doctor [--verify-fast] [--strict] [--json]

Checks:
  - required tools and canonical bootstrap contracts
  - tenant profile validation
  - environment/identity validation when present
  - AOF contract acknowledgement state
  - optional fast verify execution
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --verify-fast) VERIFY_FAST=1; shift ;;
    --strict) STRICT=1; shift ;;
    --json) JSON_MODE=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "ERROR: unknown arg: $1" >&2; usage; exit 2 ;;
  esac
done

FAILS=0
WARNS=0

fail() { echo "FAIL: $*" >&2; FAILS=$((FAILS + 1)); }
warn() { echo "WARN: $*" >&2; WARNS=$((WARNS + 1)); }
ok() {
  if [[ "$JSON_MODE" -eq 0 ]]; then
    echo "OK: $*"
  fi
}

check_tool() {
  local tool="$1"
  if command -v "$tool" >/dev/null 2>&1; then
    ok "tool present: $tool"
  else
    fail "tool missing: $tool"
  fi
}

check_file() {
  local path="$1"
  if [[ -f "$path" ]]; then
    ok "file present: ${path#$ROOT/}"
  else
    fail "file missing: ${path#$ROOT/}"
  fi
}

if [[ "$JSON_MODE" -eq 0 ]]; then
  echo "spine.doctor"
  echo "root: $ROOT"
  echo ""
fi

check_tool bash
check_tool git
check_tool jq
check_tool yq
check_tool python3
check_tool rg

check_file "$BOOTSTRAP_CONTRACT"
check_file "$PATH_BASELINE"
check_file "$TENANT_PROFILE"
check_file "$TENANT_SCHEMA"

tenant_status="fail"
if [[ -f "$TENANT_PROFILE" && -f "$TENANT_SCHEMA" ]]; then
  if "$ROOT/ops/plugins/tenant/bin/tenant-profile-validate" --profile "$TENANT_PROFILE" >/dev/null 2>&1; then
    tenant_status="ok"
    ok "tenant profile validation passed"
  else
    fail "tenant profile validation failed"
  fi
fi

profile_spine_root=""
if [[ -f "$TENANT_PROFILE" ]]; then
  profile_spine_root="$(yq -r '.runtime.spine_root // ""' "$TENANT_PROFILE" 2>/dev/null || echo "")"
fi
if [[ -n "$profile_spine_root" && "$profile_spine_root" != "$ROOT" ]]; then
  warn "tenant runtime.spine_root differs from this execution root (expected in worktrees)"
fi

env_status="missing"
if [[ -f "$ENV_FILE" && -f "$IDENTITY_FILE" ]]; then
  if "$ROOT/ops/plugins/aof/bin/validate-environment.sh" \
      --environment-file "$ENV_FILE" \
      --identity-file "$IDENTITY_FILE" >/dev/null 2>&1; then
    env_status="ok"
    ok "environment + identity validation passed"
  else
    env_status="invalid"
    fail "environment + identity validation failed"
  fi
elif [[ -f "$ENV_FILE" || -f "$IDENTITY_FILE" ]]; then
  env_status="partial"
  fail "partial bootstrap state detected (.environment/.identity mismatch)"
else
  env_status="missing"
  warn "environment files are missing; run spine.init"
fi

ack_state="unknown"
if [[ -f "$ENV_FILE" ]]; then
  ack_output="$("$ROOT/ops/plugins/aof/bin/contract-read-check.sh" --status --contract-file "$ENV_FILE" 2>/dev/null || true)"
  ack_state="$(printf '%s\n' "$ack_output" | awk -F': *' '/marker_state/ {print $2}' | tail -1)"
  ack_state="${ack_state:-unknown}"
  case "$ack_state" in
    current) ok "contract acknowledgment: current" ;;
    stale|missing) warn "contract acknowledgment: $ack_state (run aof.contract.acknowledge)" ;;
    *) warn "contract acknowledgment status unavailable" ;;
  esac
fi

verify_status="not_run"
if [[ "$VERIFY_FAST" -eq 1 ]]; then
  verify_output="$("$ROOT/ops/plugins/verify/bin/verify-run" fast 2>&1)" || true
  if printf '%s\n' "$verify_output" | grep -q "wrapper: total=" && ! printf '%s\n' "$verify_output" | grep -q "fail=[1-9]"; then
    verify_status="pass"
    ok "verify fast: pass"
  else
    verify_status="fail"
    fail "verify fast: fail"
    printf '%s\n' "$verify_output" >&2
  fi
fi

if [[ "$JSON_MODE" -eq 1 ]]; then
  jq -n \
    --arg capability "spine.doctor" \
    --arg root "$ROOT" \
    --arg tenant_status "$tenant_status" \
    --arg env_status "$env_status" \
    --arg ack_state "$ack_state" \
    --arg verify_status "$verify_status" \
    --arg profile_spine_root "$profile_spine_root" \
    --argjson failures "$FAILS" \
    --argjson warnings "$WARNS" \
    '{
      capability: $capability,
      root: $root,
      checks: {
        tenant_profile: $tenant_status,
        environment: $env_status,
        ack_state: $ack_state,
        verify_fast: $verify_status,
        tenant_profile_spine_root: $profile_spine_root
      },
      summary: {
        failures: $failures,
        warnings: $warnings,
        status: (if $failures > 0 then "fail" else "ok" end)
      }
    }'
fi

if [[ "$JSON_MODE" -eq 0 ]]; then
  echo ""
  echo "summary: failures=$FAILS warnings=$WARNS"
fi

if [[ "$FAILS" -gt 0 ]]; then
  exit 1
fi
if [[ "$STRICT" -eq 1 && "$WARNS" -gt 0 ]]; then
  echo "strict_mode: warnings treated as failures" >&2
  exit 1
fi
exit 0
