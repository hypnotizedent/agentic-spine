#!/usr/bin/env bash
# Scaffold a new VM across lifecycle/ssh/backup/health surfaces in one transaction.
# Default mode is dry-run; pass --execute to write.
set -euo pipefail

ROOT="${SPINE_ROOT:-$HOME/code/agentic-spine}"
VM_LIFECYCLE="$ROOT/ops/bindings/vm.lifecycle.yaml"
SSH_TARGETS="$ROOT/ops/bindings/ssh.targets.yaml"
BACKUP_INV="$ROOT/ops/bindings/backup.inventory.yaml"
SERVICES_HEALTH="$ROOT/ops/bindings/services.health.yaml"
VM_LIFECYCLE_DERIVED="$ROOT/ops/bindings/vm.lifecycle.derived.yaml"
PLATFORM_CONTROL="$ROOT/ops/bindings/platform.control.surfaces.yaml"
VM_DERIVED_CHECK="$ROOT/ops/plugins/vm/bin/vm-lifecycle-derived-check"
CONTROL_RECONCILE="$ROOT/ops/plugins/authority/bin/platform-control-surface-reconcile"

# shellcheck source=/Users/ronnyworks/code/agentic-spine/ops/lib/git-lock.sh
source "$ROOT/ops/lib/git-lock.sh"

EXECUTE=0
VMID=""
HOSTNAME=""
ROLE="general"
SITE_SCOPE="shop"
PROXMOX_HOST="pve"
STATUS="planning"
OWNER="@ronny"
SSH_USER="ubuntu"
LAN_IP=""
TAILSCALE_IP=""
BACKUP_CLASSIFICATION="important"
BACKUP_PROFILE="vm-primary"
BACKUP_ADMISSION_STATE="planned"
HAS_DOCKER="true"
TX_TMPDIR=""
declare -a TX_BACKUPS=()

usage() {
  cat <<'USAGE'
infra.vm.intake.scaffold - register a VM across lifecycle/ssh/backup/health.

Usage:
  infra-vm-intake-scaffold --vmid <id> --hostname <name> [options] [--execute]

Required:
  --vmid <id>
  --hostname <name>

Options:
  --role <text>                         default: general
  --site-scope <shop|home>              default: shop
  --proxmox-host <pve|proxmox-home>     default: pve
  --status <planning|provisioned|registered|active>  default: planning
  --owner <@owner>                      default: @ronny
  --ssh-user <user>                     default: ubuntu
  --lan-ip <ip>
  --tailscale-ip <ip>
  --backup-classification <critical|important|rebuildable> default: important
  --backup-profile <id>                 default: vm-primary
  --backup-admission-state <planned|production_ready> default: planned
  --has-docker <true|false>             default: true
  --execute                             apply changes (default: dry-run)

Notes:
  - For WIP/new projects, keep --status planning and --backup-admission-state planned.
  - This scaffolder creates disabled placeholder health endpoint to satisfy cross-surface registration.
USAGE
}

fail() {
  echo "FAIL: $*" >&2
  exit 1
}

cleanup() {
  release_git_lock || true
  if [[ -n "$TX_TMPDIR" && -d "$TX_TMPDIR" ]]; then
    rm -rf "$TX_TMPDIR"
  fi
  return 0
}

backup_file() {
  local target="$1"
  local backup_path="$TX_TMPDIR/$(basename "$target").${#TX_BACKUPS[@]}.bak"
  cp "$target" "$backup_path"
  TX_BACKUPS+=("$target::$backup_path")
}

rollback_transaction() {
  local pair target backup_path
  for pair in "${TX_BACKUPS[@]}"; do
    target="${pair%%::*}"
    backup_path="${pair#*::}"
    cp "$backup_path" "$target"
  done
}

require_projection_parity() {
  local lifecycle_key actual_status actual_ssh_target actual_backup_target actual_ssh_host actual_ssh_user
  local actual_backup_host actual_backup_enabled actual_health_host actual_health_url actual_health_enabled derived_host

  lifecycle_key="$(yq e -r ".vms | to_entries[] | select((.value.id == ${VMID}) or (.value.hostname == \"${HOSTNAME}\")) | .key" "$VM_LIFECYCLE" 2>/dev/null | head -n1)"
  [[ -n "$lifecycle_key" && "$lifecycle_key" != "null" ]] || fail "transaction rolled back (vm lifecycle entry missing for ${HOSTNAME})"

  actual_status="$(yq e -r ".vms[$lifecycle_key].status // \"\"" "$VM_LIFECYCLE" 2>/dev/null || true)"
  [[ "$actual_status" == "$STATUS" ]] || fail "transaction rolled back (vm lifecycle status drift: expected ${STATUS}, got ${actual_status:-<empty>})"

  actual_ssh_target="$(yq e -r ".vms[$lifecycle_key].ssh_target // \"\"" "$VM_LIFECYCLE" 2>/dev/null || true)"
  [[ "$actual_ssh_target" == "$HOSTNAME" ]] || fail "transaction rolled back (vm lifecycle ssh_target drift: expected ${HOSTNAME}, got ${actual_ssh_target:-<empty>})"

  actual_backup_target="$(yq e -r ".vms[$lifecycle_key].backup_target // \"\"" "$VM_LIFECYCLE" 2>/dev/null || true)"
  [[ "$actual_backup_target" == "$BACKUP_TARGET" ]] || fail "transaction rolled back (vm lifecycle backup_target drift: expected ${BACKUP_TARGET}, got ${actual_backup_target:-<empty>})"

  actual_ssh_host="$(yq e -r ".ssh.targets[] | select(.id == \"${HOSTNAME}\") | .host // \"\"" "$SSH_TARGETS" 2>/dev/null | head -n1 || true)"
  [[ "$actual_ssh_host" == "$SSH_HOST" ]] || fail "transaction rolled back (ssh target host drift: expected ${SSH_HOST}, got ${actual_ssh_host:-<empty>})"

  actual_ssh_user="$(yq e -r ".ssh.targets[] | select(.id == \"${HOSTNAME}\") | .user // \"\"" "$SSH_TARGETS" 2>/dev/null | head -n1 || true)"
  [[ "$actual_ssh_user" == "$SSH_USER" ]] || fail "transaction rolled back (ssh target user drift: expected ${SSH_USER}, got ${actual_ssh_user:-<empty>})"

  actual_backup_host="$(yq e -r ".targets[] | select(.name == \"${BACKUP_TARGET}\") | .host // \"\"" "$BACKUP_INV" 2>/dev/null | head -n1 || true)"
  [[ "$actual_backup_host" == "$PROXMOX_HOST" ]] || fail "transaction rolled back (backup target host drift: expected ${PROXMOX_HOST}, got ${actual_backup_host:-<empty>})"

  actual_backup_enabled="$(yq e -r ".targets[] | select(.name == \"${BACKUP_TARGET}\") | (.enabled | tostring)" "$BACKUP_INV" 2>/dev/null | head -n1 || true)"
  [[ "$actual_backup_enabled" == "$TARGET_ENABLED" ]] || fail "transaction rolled back (backup target enabled drift: expected ${TARGET_ENABLED}, got ${actual_backup_enabled:-<empty>})"

  actual_health_host="$(yq e -r ".endpoints[] | select(.id == \"${HEALTH_ID}\") | .host // \"\"" "$SERVICES_HEALTH" 2>/dev/null | head -n1 || true)"
  [[ "$actual_health_host" == "$HOSTNAME" ]] || fail "transaction rolled back (health placeholder host drift: expected ${HOSTNAME}, got ${actual_health_host:-<empty>})"

  actual_health_url="$(yq e -r ".endpoints[] | select(.id == \"${HEALTH_ID}\") | .url // \"\"" "$SERVICES_HEALTH" 2>/dev/null | head -n1 || true)"
  [[ "$actual_health_url" == "$HEALTH_URL" ]] || fail "transaction rolled back (health placeholder url drift: expected ${HEALTH_URL}, got ${actual_health_url:-<empty>})"

  actual_health_enabled="$(yq e -r ".endpoints[] | select(.id == \"${HEALTH_ID}\") | (.enabled | tostring)" "$SERVICES_HEALTH" 2>/dev/null | head -n1 || true)"
  [[ "$actual_health_enabled" == "false" ]] || fail "transaction rolled back (health placeholder enabled drift: expected false, got ${actual_health_enabled:-<empty>})"

  derived_host="$(yq e -r ".active_vms[]? | select(.id == (${VMID} | tonumber)) | .hostname // \"\"" "$VM_LIFECYCLE_DERIVED" 2>/dev/null | head -n1 || true)"
  if [[ "$STATUS" == "active" ]]; then
    [[ "$derived_host" == "$HOSTNAME" ]] || fail "transaction rolled back (active VM missing from vm.lifecycle.derived.yaml)"
  else
    [[ -z "$derived_host" ]] || fail "transaction rolled back (non-active VM leaked into vm.lifecycle.derived.yaml)"
  fi
}

trap cleanup EXIT INT TERM

while [[ $# -gt 0 ]]; do
  case "$1" in
    --) shift ;;
    --vmid) VMID="${2:?}"; shift 2 ;;
    --hostname) HOSTNAME="${2:?}"; shift 2 ;;
    --role) ROLE="${2:?}"; shift 2 ;;
    --site-scope) SITE_SCOPE="${2:?}"; shift 2 ;;
    --proxmox-host) PROXMOX_HOST="${2:?}"; shift 2 ;;
    --status) STATUS="${2:?}"; shift 2 ;;
    --owner) OWNER="${2:?}"; shift 2 ;;
    --ssh-user) SSH_USER="${2:?}"; shift 2 ;;
    --lan-ip) LAN_IP="${2:?}"; shift 2 ;;
    --tailscale-ip) TAILSCALE_IP="${2:?}"; shift 2 ;;
    --backup-classification) BACKUP_CLASSIFICATION="${2:?}"; shift 2 ;;
    --backup-profile) BACKUP_PROFILE="${2:?}"; shift 2 ;;
    --backup-admission-state) BACKUP_ADMISSION_STATE="${2:?}"; shift 2 ;;
    --has-docker) HAS_DOCKER="${2:?}"; shift 2 ;;
    --execute) EXECUTE=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) fail "unknown arg: $1" ;;
  esac
done

[[ -n "$VMID" ]] || fail "--vmid required"
[[ -n "$HOSTNAME" ]] || fail "--hostname required"
[[ "$VMID" =~ ^[0-9]+$ ]] || fail "--vmid must be numeric"
[[ "$SITE_SCOPE" =~ ^(shop|home)$ ]] || fail "--site-scope must be shop|home"
[[ "$STATUS" =~ ^(planning|provisioned|registered|active)$ ]] || fail "invalid --status"
[[ "$BACKUP_CLASSIFICATION" =~ ^(critical|important|rebuildable)$ ]] || fail "invalid --backup-classification"
[[ "$BACKUP_ADMISSION_STATE" =~ ^(planned|production_ready)$ ]] || fail "invalid --backup-admission-state"
[[ "$HAS_DOCKER" =~ ^(true|false)$ ]] || fail "--has-docker must be true|false"

for dep in yq python3; do
  command -v "$dep" >/dev/null 2>&1 || fail "missing dependency: $dep"
done

for f in "$VM_LIFECYCLE" "$SSH_TARGETS" "$BACKUP_INV" "$SERVICES_HEALTH" "$VM_LIFECYCLE_DERIVED" "$PLATFORM_CONTROL"; do
  [[ -f "$f" ]] || fail "missing $f"
done
[[ -x "$VM_DERIVED_CHECK" ]] || fail "missing helper: $VM_DERIVED_CHECK"
[[ -x "$CONTROL_RECONCILE" ]] || fail "missing helper: $CONTROL_RECONCILE"

if yq -e ".vms[] | select(.id == ${VMID} or .hostname == \"${HOSTNAME}\")" "$VM_LIFECYCLE" >/dev/null 2>&1; then
  fail "vm.lifecycle already contains vmid=$VMID or hostname=$HOSTNAME"
fi
if yq -e ".ssh.targets[] | select(.id == \"${HOSTNAME}\")" "$SSH_TARGETS" >/dev/null 2>&1; then
  fail "ssh target already exists for id=$HOSTNAME"
fi

BACKUP_TARGET="vm-${VMID}-${HOSTNAME}-primary"
HEALTH_ID="${HOSTNAME}-health-placeholder"

if yq -e ".targets[] | select(.name == \"${BACKUP_TARGET}\")" "$BACKUP_INV" >/dev/null 2>&1; then
  fail "backup target already exists: $BACKUP_TARGET"
fi
if yq -e ".endpoints[] | select(.id == \"${HEALTH_ID}\")" "$SERVICES_HEALTH" >/dev/null 2>&1; then
  fail "services.health endpoint id already exists: $HEALTH_ID"
fi

if [[ "$PROXMOX_HOST" == "proxmox-home" ]]; then
  DEST_LANE="nas-offsite-vm"
else
  DEST_LANE="pve-vzdump-primary"
fi

if [[ "$BACKUP_CLASSIFICATION" == "rebuildable" ]]; then
  STALE_HOURS="168"
  SCHEDULE_CLASS="weekly-est"
  RESTORE_CLASS="vm-dry-run-quarterly"
elif [[ "$BACKUP_CLASSIFICATION" == "critical" ]]; then
  STALE_HOURS="26"
  SCHEDULE_CLASS="daily-primary-est"
  RESTORE_CLASS="tier1-small-state-dry-run-quarterly"
else
  STALE_HOURS="48"
  SCHEDULE_CLASS="daily-primary-est"
  RESTORE_CLASS="vm-dry-run-quarterly"
fi

SSH_HOST="$TAILSCALE_IP"
if [[ -z "$SSH_HOST" ]]; then
  SSH_HOST="$LAN_IP"
fi
[[ -n "$SSH_HOST" ]] || SSH_HOST="PENDING_HOST"

if [[ "$PROXMOX_HOST" == "proxmox-home" ]]; then
  BACKUP_BASE="/mnt/pve/synology-backups/dump"
else
  BACKUP_BASE="/tank/backups/vzdump/dump"
fi

TARGET_ENABLED="false"
if [[ "$BACKUP_ADMISSION_STATE" == "production_ready" && "$STATUS" == "active" ]]; then
  TARGET_ENABLED="true"
fi

HEALTH_URL="http://${SSH_HOST}:80/health"

if [[ "$EXECUTE" -eq 0 ]]; then
  echo "infra.vm.intake.scaffold"
  echo "mode: dry-run"
  echo "vmid: $VMID"
  echo "hostname: $HOSTNAME"
  echo "status: $STATUS"
  echo "backup_target: $BACKUP_TARGET"
  echo "backup_admission_state: $BACKUP_ADMISSION_STATE"
  echo "destination_lane: $DEST_LANE"
  echo "target_enabled: $TARGET_ENABLED"
  echo "ssh_host: $SSH_HOST"
  echo "health_placeholder: $HEALTH_ID -> $HEALTH_URL (enabled=false)"
  echo "reconcile: vm.lifecycle.derived + platform.control.surfaces"
  echo "apply: rerun with --execute"
  exit 0
fi

export VMID HOSTNAME ROLE SITE_SCOPE PROXMOX_HOST STATUS OWNER SSH_USER LAN_IP TAILSCALE_IP BACKUP_TARGET HAS_DOCKER BACKUP_PROFILE BACKUP_ADMISSION_STATE DEST_LANE STALE_HOURS SCHEDULE_CLASS RESTORE_CLASS BACKUP_BASE BACKUP_CLASSIFICATION TARGET_ENABLED SSH_HOST HEALTH_ID HEALTH_URL

TX_TMPDIR="$(mktemp -d)"
backup_file "$VM_LIFECYCLE"
backup_file "$SSH_TARGETS"
backup_file "$BACKUP_INV"
backup_file "$SERVICES_HEALTH"
backup_file "$VM_LIFECYCLE_DERIVED"
backup_file "$PLATFORM_CONTROL"
acquire_git_lock infra_vm_intake || exit 1

if ! {
  now_date="$(date -u +%Y-%m-%d)"
  export NOW_DATE="$now_date"
  VM_ENTRY="$TX_TMPDIR/vm-entry.yaml"
  SSH_ENTRY="$TX_TMPDIR/ssh-entry.yaml"
  BACKUP_RUNTIME_ENTRY="$TX_TMPDIR/backup-runtime-entry.yaml"
  BACKUP_TARGET_ENTRY="$TX_TMPDIR/backup-target-entry.yaml"
  HEALTH_ENTRY="$TX_TMPDIR/health-entry.yaml"

  python3 - "$VM_ENTRY" "$SSH_ENTRY" "$BACKUP_RUNTIME_ENTRY" "$BACKUP_TARGET_ENTRY" "$HEALTH_ENTRY" <<'PY'
from __future__ import annotations

import os
import sys
from pathlib import Path

import yaml

vm_entry, ssh_entry, backup_runtime_entry, backup_target_entry, health_entry = [
    Path(arg) for arg in sys.argv[1:6]
]

backup_classification = os.environ["BACKUP_CLASSIFICATION"]
if backup_classification == "critical":
    data_class = "tier1_critical"
elif backup_classification == "rebuildable":
    data_class = "payload_regenerable"
else:
    data_class = "small_state"

vm_payload = {
    "id": int(os.environ["VMID"]),
    "hostname": os.environ["HOSTNAME"],
    "proxmox_host": os.environ["PROXMOX_HOST"],
    "role": os.environ["ROLE"],
    "owner": os.environ["OWNER"],
    "status": os.environ["STATUS"],
    "created_at": os.environ["NOW_DATE"],
    "profile": "spine-ready-v1",
    "site_scope": os.environ["SITE_SCOPE"],
    "lan_ip": os.environ["LAN_IP"] or None,
    "tailscale_ip": os.environ["TAILSCALE_IP"] or None,
    "ssh_target": os.environ["HOSTNAME"],
    "ssh_user": os.environ["SSH_USER"],
    "os": "ubuntu-24.04",
    "resources": {"cpu_cores": 2, "memory_mb": 4096, "boot_disk_gb": 40},
    "storage_tier": "boot-only",
    "stacks": [],
    "services": [],
    "backup_target": os.environ["BACKUP_TARGET"],
    "has_docker": os.environ["HAS_DOCKER"] == "true",
    "health_probe_policy": "full",
    "decommission_policy": "requires_migration_first",
    "description": "Scaffolded by infra.vm.intake.scaffold; refine before active promotion.",
}

ssh_payload = {
    "id": os.environ["HOSTNAME"],
    "host": os.environ["SSH_HOST"],
    "user": os.environ["SSH_USER"],
    "description": "Scaffolded VM target; verify IP/user before promotion to active.",
    "tags": ["vm", "scaffold", os.environ["SITE_SCOPE"]],
}

backup_runtime_payload = {
    "unit_id": f"vm-{os.environ['VMID']}-{os.environ['HOSTNAME']}",
    "kind": "vm",
    "hostname": os.environ["HOSTNAME"],
    "backup_profile": os.environ["BACKUP_PROFILE"],
    "backup_admission_state": os.environ["BACKUP_ADMISSION_STATE"],
    "data_class": data_class,
    "include_paths": ["vm-disk"],
    "exclude_paths": ["payload_regenerable"],
    "destination_lane": os.environ["DEST_LANE"],
    "schedule_class": os.environ["SCHEDULE_CLASS"],
    "restore_class": os.environ["RESTORE_CLASS"],
    "inventory_targets": [os.environ["BACKUP_TARGET"]],
}

backup_target_payload = {
    "name": os.environ["BACKUP_TARGET"],
    "enabled": os.environ["TARGET_ENABLED"] == "true",
    "kind": "file_glob",
    "host": os.environ["PROXMOX_HOST"],
    "base_path": os.environ["BACKUP_BASE"],
    "glob": f"vzdump-qemu-{os.environ['VMID']}-*.vma.zst",
    "stale_after_hours": int(os.environ["STALE_HOURS"]),
    "classification": backup_classification,
    "description": "Scaffold target from infra.vm.intake.scaffold (enable when production_ready + active).",
}

health_payload = {
    "id": os.environ["HEALTH_ID"],
    "host": os.environ["HOSTNAME"],
    "url": os.environ["HEALTH_URL"],
    "expect": 200,
    "enabled": False,
    "description": "Scaffold placeholder health endpoint. Replace with real service probes before active enforcement.",
}

for path, payload in (
    (vm_entry, vm_payload),
    (ssh_entry, ssh_payload),
    (backup_runtime_entry, backup_runtime_payload),
    (backup_target_entry, backup_target_payload),
    (health_entry, health_payload),
):
    path.write_text(yaml.safe_dump(payload, sort_keys=False), encoding="utf-8")
PY

  # vm.lifecycle
  yq -i ".vms += [load(\"$VM_ENTRY\")]" "$VM_LIFECYCLE"

  # ssh.targets
  yq -i ".ssh.targets += [load(\"$SSH_ENTRY\")]" "$SSH_TARGETS"

  # backup runtime unit + target
  yq -i ".runtime_units += [load(\"$BACKUP_RUNTIME_ENTRY\")] | .targets += [load(\"$BACKUP_TARGET_ENTRY\")]" "$BACKUP_INV"

  # services.health placeholder
  yq -i ".endpoints += [load(\"$HEALTH_ENTRY\")]" "$SERVICES_HEALTH"

  "$VM_DERIVED_CHECK" --write --hostname "$HOSTNAME" >/dev/null
  "$VM_DERIVED_CHECK" --hostname "$HOSTNAME" >/dev/null
  "$CONTROL_RECONCILE" --write >/dev/null
  "$CONTROL_RECONCILE" --check >/dev/null
  require_projection_parity
}; then
  rollback_transaction
  fail "intake transaction rolled back"
fi

echo "infra.vm.intake.scaffold"
echo "mode: execute"
echo "vmid: $VMID"
echo "hostname: $HOSTNAME"
echo "backup_target: $BACKUP_TARGET"
echo "target_enabled: $TARGET_ENABLED"
echo "reconcile: vm.lifecycle.derived + platform.control.surfaces"
echo "status: OK"
