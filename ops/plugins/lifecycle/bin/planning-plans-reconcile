#!/usr/bin/env bash
set -euo pipefail

# planning.plans.reconcile — Detect and repair plans lifecycle/projection drift.
#
# Usage:
#   planning-plans-reconcile [--check|--fix] [--json] [--no-archive-orphans] [--no-create-placeholders]

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)"
PLANS_DIR="$ROOT/mailroom/state/plans"
PLANS_INDEX="$PLANS_DIR/index.yaml"
LIFECYCLE_CONTRACT="$ROOT/ops/bindings/plans.lifecycle.yaml"
source "$ROOT/ops/lib/git-lock.sh"

MODE="check"
JSON_MODE=0
ARCHIVE_ORPHANS=1
CREATE_PLACEHOLDERS=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --) shift ;;
    --check) MODE="check"; shift ;;
    --fix) MODE="fix"; shift ;;
    --json) JSON_MODE=1; shift ;;
    --no-archive-orphans) ARCHIVE_ORPHANS=0; shift ;;
    --no-create-placeholders) CREATE_PLACEHOLDERS=0; shift ;;
    -h|--help)
      cat <<'EOF'
Usage: planning-plans-reconcile [--check|--fix] [--json] [--no-archive-orphans] [--no-create-placeholders]

Modes:
  --check  Report lifecycle/projection drift and exit non-zero when drift is present.
  --fix    Normalize legacy statuses, enforce terminal audit fields, create missing plan
           projection docs, and archive orphan docs.
EOF
      exit 0
      ;;
    *)
      echo "Unknown arg: $1" >&2
      exit 2
      ;;
  esac
done

[[ -f "$LIFECYCLE_CONTRACT" ]] || {
  echo "FAIL: plans lifecycle contract not found: $LIFECYCLE_CONTRACT" >&2
  exit 1
}

if [[ "$MODE" == "fix" ]]; then
  acquire_git_lock plans || exit 1
  trap 'release_git_lock' EXIT INT TERM
fi

python3 - "$PLANS_DIR" "$PLANS_INDEX" "$LIFECYCLE_CONTRACT" "$MODE" "$JSON_MODE" "$ARCHIVE_ORPHANS" "$CREATE_PLACEHOLDERS" <<'PY'
from __future__ import annotations

from datetime import datetime, timezone
import json
import re
import shutil
import sys
from pathlib import Path
from typing import Any

import yaml

plans_dir = Path(sys.argv[1])
index_path = Path(sys.argv[2])
contract_path = Path(sys.argv[3])
mode = sys.argv[4]
json_mode = sys.argv[5] == "1"
archive_orphans = sys.argv[6] == "1"
create_placeholders = sys.argv[7] == "1"
fix_mode = mode == "fix"

now_utc = datetime.now(timezone.utc)
now_utc_text = now_utc.strftime("%Y-%m-%dT%H:%M:%SZ")
today = now_utc.strftime("%Y-%m-%d")
ts_slug = now_utc.strftime("%Y%m%dT%H%M%SZ")


def load_yaml(path: Path) -> Any:
    if not path.exists():
        return None
    text = path.read_text(encoding="utf-8")
    if not text.strip():
        return None
    return yaml.safe_load(text)


contract = load_yaml(contract_path) or {}
if not isinstance(contract, dict):
    raise SystemExit(f"FAIL: lifecycle contract must be a YAML map: {contract_path}")

status_rows = contract.get("statuses") or []
if not isinstance(status_rows, list):
    raise SystemExit("FAIL: plans lifecycle contract statuses must be a list")

canonical_statuses: set[str] = set()
for row in status_rows:
    if isinstance(row, dict):
        sid = str(row.get("id") or "").strip()
        if sid:
            canonical_statuses.add(sid)

if not canonical_statuses:
    canonical_statuses = {"deferred", "promoted", "retired", "canceled"}

status_aliases_raw = contract.get("status_aliases") or {}
status_aliases: dict[str, str] = {}
if isinstance(status_aliases_raw, dict):
    for k, v in status_aliases_raw.items():
        kk = str(k or "").strip()
        vv = str(v or "").strip()
        if kk and vv:
            status_aliases[kk] = vv

legacy_rows = contract.get("legacy_tombstones") or []
legacy_map: dict[str, dict[str, Any]] = {}
if isinstance(legacy_rows, list):
    for row in legacy_rows:
        if not isinstance(row, dict):
            continue
        legacy = str(row.get("legacy_status") or "").strip()
        canonical = str(row.get("canonical_status") or "").strip()
        if legacy and canonical:
            legacy_map[legacy] = row

required_fields = contract.get("required_fields") or {}
if not isinstance(required_fields, dict):
    required_fields = {}

projection_model = contract.get("projection_model") or {}
if not isinstance(projection_model, dict):
    projection_model = {}

orphan_archive_dir = projection_model.get("orphan_archive_dir")
if not orphan_archive_dir:
    orphan_archive_dir = "mailroom/state/plans/_orphans"

# Prepare index document.
index_doc = load_yaml(index_path)
if index_doc is None:
    index_doc = {"version": "1.0", "updated_at": today, "plans": []}
if not isinstance(index_doc, dict):
    raise SystemExit(f"FAIL: plans index must be a YAML map: {index_path}")

plans = index_doc.get("plans")
if plans is None:
    plans = []
if not isinstance(plans, list):
    raise SystemExit("FAIL: plans index key 'plans' must be a list")


def canonical_plan_id_from_doc(path: Path) -> str:
    stem = path.stem.strip()
    # Normalize common projection naming (PLAN-ID-YYYYMMDD[-YYYYMMDD].md -> PLAN-ID).
    m = re.match(r"^(PLAN-[A-Z0-9-]+?)(?:-\d{8}(?:-\d{8})?)?$", stem)
    if m:
        return m.group(1)
    return stem


def build_placeholder_doc(plan_row: dict[str, Any]) -> str:
    plan_id = str(plan_row.get("plan_id") or "").strip() or "PLAN-UNKNOWN"
    status = str(plan_row.get("status") or "deferred").strip() or "deferred"
    source_loop = str(plan_row.get("source_loop_id") or "").strip() or "LOOP-UNKNOWN"
    owner = str(plan_row.get("owner") or "").strip() or "unknown"
    review_date = str(plan_row.get("review_date") or "").strip() or "1970-01-01"
    desc = str(plan_row.get("description") or "Projection placeholder generated by planning.plans.reconcile.").strip()

    return (
        f"# {plan_id}\n\n"
        f"> Projection placeholder generated by `planning.plans.reconcile` on {today}.\n"
        f"> Authority row lives in `mailroom/state/plans/index.yaml`.\n\n"
        f"- status: `{status}`\n"
        f"- source_loop_id: `{source_loop}`\n"
        f"- owner: `{owner}`\n"
        f"- review_date: `{review_date}`\n\n"
        f"## Description\n\n{desc}\n"
    )


def ensure_terminal_fields(row: dict[str, Any], canonical_status: str, source_status: str) -> list[str]:
    changes: list[str] = []

    if canonical_status == "retired":
        reason = str(row.get("retired_reason") or "").strip()
        if not reason:
            reason = str(row.get("completed_note") or "").strip()
        if not reason:
            legacy = legacy_map.get(source_status) or {}
            reason = str(legacy.get("default_retired_reason") or "").strip()
        if not reason:
            reason = "Retired by lifecycle reconcile (legacy normalization)."

        if not str(row.get("retired_reason") or "").strip():
            row["retired_reason"] = reason
            changes.append("retired_reason")
        if not str(row.get("retired_at_utc") or "").strip():
            row["retired_at_utc"] = now_utc_text
            changes.append("retired_at_utc")
        if not str(row.get("retired_from_status") or "").strip() and source_status and source_status != canonical_status:
            row["retired_from_status"] = source_status
            changes.append("retired_from_status")

    if canonical_status == "canceled":
        if not str(row.get("canceled_reason") or "").strip():
            row["canceled_reason"] = "Canceled by lifecycle reconcile (missing reason backfill)."
            changes.append("canceled_reason")
        if not str(row.get("canceled_at_utc") or "").strip():
            row["canceled_at_utc"] = now_utc_text
            changes.append("canceled_at_utc")

    if canonical_status == "promoted":
        if not str(row.get("promoted_at_utc") or "").strip():
            row["promoted_at_utc"] = now_utc_text
            changes.append("promoted_at_utc")

    return changes


# Projection doc inventory.
doc_paths = sorted(plans_dir.glob("PLAN-*.md"))
doc_by_plan_id: dict[str, Path] = {}
duplicate_doc_paths: list[Path] = []
for doc_path in doc_paths:
    canonical_id = canonical_plan_id_from_doc(doc_path)
    if canonical_id in doc_by_plan_id:
        duplicate_doc_paths.append(doc_path)
        continue
    doc_by_plan_id[canonical_id] = doc_path

errors: list[str] = []
warnings: list[str] = []
actions: list[str] = []

noncanonical_status = 0
legacy_normalized = 0
missing_terminal_audit = 0
missing_projection_docs = 0
orphan_projection_docs = 0
duplicate_plan_ids = 0
unfixable_rows = 0

seen_plan_ids: set[str] = set()
plan_ids_from_index: list[str] = []
index_changed = False

required_all = required_fields.get("all") or []
if not isinstance(required_all, list):
    required_all = []

for idx, raw_row in enumerate(plans):
    if not isinstance(raw_row, dict):
        errors.append(f"plans[{idx}] is not a YAML map")
        unfixable_rows += 1
        continue

    row = raw_row
    plan_id = str(row.get("plan_id") or "").strip()
    if not plan_id:
        errors.append(f"plans[{idx}] missing plan_id")
        unfixable_rows += 1
        continue

    if plan_id in seen_plan_ids:
        duplicate_plan_ids += 1
        errors.append(f"{plan_id}: duplicate plan_id in index")
        continue
    seen_plan_ids.add(plan_id)
    plan_ids_from_index.append(plan_id)

    # Required all fields check (report-only; row-level partial data may be historical).
    for required in required_all:
        if not str(row.get(str(required) or "") or "").strip():
            warnings.append(f"{plan_id}: missing required field '{required}'")

    source_status = str(row.get("status") or "").strip() or "deferred"
    normalized_status = source_status

    if normalized_status in status_aliases:
        normalized_status = status_aliases[normalized_status]

    if normalized_status in legacy_map:
        legacy_normalized += 1
        canonical = str(legacy_map[normalized_status].get("canonical_status") or "").strip() or normalized_status
        if fix_mode:
            row["legacy_status_tombstoned_from"] = source_status
            row["status"] = canonical
            index_changed = True
            actions.append(f"{plan_id}: normalized legacy status {source_status}->{canonical}")
        normalized_status = canonical

    if normalized_status not in canonical_statuses:
        noncanonical_status += 1
        errors.append(
            f"{plan_id}: non-canonical status '{source_status}' (allowed: {', '.join(sorted(canonical_statuses))})"
        )
        continue

    # Handle alias-only normalization where not legacy mapping.
    if normalized_status != source_status and source_status not in legacy_map:
        if fix_mode:
            row["status"] = normalized_status
            index_changed = True
            actions.append(f"{plan_id}: normalized status alias {source_status}->{normalized_status}")

    # Terminal audit requirements.
    required_for_status = required_fields.get(normalized_status) or []
    if not isinstance(required_for_status, list):
        required_for_status = []

    missing = []
    for field in required_for_status:
        field_name = str(field or "").strip()
        if not field_name:
            continue
        if not str(row.get(field_name) or "").strip():
            missing.append(field_name)

    if missing:
        missing_terminal_audit += 1
        if fix_mode:
            changed_fields = ensure_terminal_fields(row, normalized_status, source_status)
            if changed_fields:
                index_changed = True
                actions.append(f"{plan_id}: backfilled {', '.join(changed_fields)}")
                # Re-check after backfill.
                missing = [
                    field
                    for field in required_for_status
                    if not str(row.get(str(field) or "") or "").strip()
                ]
        if missing:
            errors.append(
                f"{plan_id}: status={normalized_status} missing required fields: {', '.join(missing)}"
            )

# Keep deterministic plan ordering.
if fix_mode:
    plans.sort(key=lambda item: str(item.get("plan_id") or ""))

index_set = set(plan_ids_from_index)

# Missing projection docs for authority entries.
for plan_id in plan_ids_from_index:
    if plan_id in doc_by_plan_id:
        continue
    missing_projection_docs += 1
    if fix_mode and create_placeholders:
        target = plans_dir / f"{plan_id}.md"
        # Resolve source row for placeholder body.
        row = next((r for r in plans if isinstance(r, dict) and str(r.get("plan_id") or "").strip() == plan_id), {})
        target.write_text(build_placeholder_doc(row if isinstance(row, dict) else {}), encoding="utf-8")
        actions.append(f"{plan_id}: created projection placeholder {target.name}")

# Orphan docs not represented in authority index.
orphan_targets: list[Path] = []
for canonical_id, doc_path in doc_by_plan_id.items():
    if canonical_id not in index_set:
        orphan_projection_docs += 1
        orphan_targets.append(doc_path)

# Treat duplicate docs as orphaned projections too.
for dup in duplicate_doc_paths:
    orphan_projection_docs += 1
    orphan_targets.append(dup)

if fix_mode and archive_orphans and orphan_targets:
    archive_dir = contract_path.parent.parent.parent / orphan_archive_dir
    archive_dir.mkdir(parents=True, exist_ok=True)
    for doc_path in sorted(orphan_targets):
        candidate = archive_dir / f"{ts_slug}__{doc_path.name}"
        counter = 1
        while candidate.exists():
            candidate = archive_dir / f"{ts_slug}-{counter}__{doc_path.name}"
            counter += 1
        shutil.move(str(doc_path), str(candidate))
        actions.append(f"archived orphan projection {doc_path.name} -> {candidate.relative_to(contract_path.parent.parent.parent)}")

# Persist index if changed.
if fix_mode:
    if index_changed:
        index_doc["plans"] = plans
        index_doc["updated_at"] = today
        if not str(index_doc.get("version") or "").strip():
            index_doc["version"] = "1.0"
        index_path.write_text(
            yaml.safe_dump(index_doc, sort_keys=False, allow_unicode=False),
            encoding="utf-8",
        )

summary = {
    "mode": mode,
    "index": str(index_path),
    "lifecycle_contract": str(contract_path),
    "plans_total": len(plan_ids_from_index),
    "projection_docs_total": len(doc_paths),
    "noncanonical_status": noncanonical_status,
    "legacy_normalized": legacy_normalized,
    "missing_terminal_audit": missing_terminal_audit,
    "missing_projection_docs": missing_projection_docs,
    "orphan_projection_docs": orphan_projection_docs,
    "duplicate_plan_ids": duplicate_plan_ids,
    "unfixable_rows": unfixable_rows,
    "actions_applied": len(actions),
}

payload = {
    "capability": "planning.plans.reconcile",
    "summary": summary,
    "errors": errors,
    "warnings": warnings,
    "actions": actions,
}

if json_mode:
    print(json.dumps(payload, indent=2))
else:
    print("planning.plans.reconcile")
    for key in [
        "mode",
        "plans_total",
        "projection_docs_total",
        "noncanonical_status",
        "legacy_normalized",
        "missing_terminal_audit",
        "missing_projection_docs",
        "orphan_projection_docs",
        "duplicate_plan_ids",
        "unfixable_rows",
        "actions_applied",
    ]:
        print(f"{key}: {summary[key]}")
    if warnings:
        print("warnings:")
        for line in warnings:
            print(f"- {line}")
    if errors:
        print("errors:")
        for line in errors:
            print(f"- {line}")
    if actions:
        print("actions:")
        for line in actions:
            print(f"- {line}")

# Exit behavior:
# - check mode: fail on any drift or errors.
# - fix mode: fail only when unfixable/remaining errors exist.
drift_present = any(
    summary[k] > 0
    for k in [
        "noncanonical_status",
        "missing_terminal_audit",
        "missing_projection_docs",
        "orphan_projection_docs",
        "duplicate_plan_ids",
        "unfixable_rows",
    ]
)

if mode == "check":
    raise SystemExit(1 if (drift_present or errors) else 0)

raise SystemExit(1 if (errors or unfixable_rows > 0) else 0)
PY
