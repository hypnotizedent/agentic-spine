#!/usr/bin/env bash
set -euo pipefail

# planning.plans.retire — Mark deferred intent plan as retired (non-destructive terminal state).
#
# Usage:
#   planning-plans-retire --plan-id PLAN-ID --reason "..."

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)"
PLANS_INDEX="$ROOT/mailroom/state/plans/index.yaml"

PLAN_ID=""
REASON=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --) shift ;;
    --plan-id) PLAN_ID="${2:-}"; shift 2 ;;
    --plan-id=*) PLAN_ID="${1#*=}"; shift ;;
    --reason) REASON="${2:-}"; shift 2 ;;
    --reason=*) REASON="${1#*=}"; shift ;;
    -h|--help)
      cat <<'EOF'
Usage: planning-plans-retire --plan-id PLAN-ID --reason "..."

Sets plan status to retired without deleting historical intent.
EOF
      exit 0
      ;;
    *) echo "Unknown arg: $1" >&2; exit 2 ;;
  esac
done

[[ -n "$PLAN_ID" ]] || { echo "FAIL: --plan-id required" >&2; exit 2; }
[[ -n "$REASON" ]] || { echo "FAIL: --reason required" >&2; exit 2; }
[[ -f "$PLANS_INDEX" ]] || { echo "FAIL: plans index not found: $PLANS_INDEX" >&2; exit 1; }

ACTOR="${SPINE_AGENT_ID:-${USER:-unknown}}"

python3 - "$PLANS_INDEX" "$PLAN_ID" "$REASON" "$ACTOR" <<'PY'
from datetime import datetime, timezone
import re
import sys
from pathlib import Path

import yaml

index_path = Path(sys.argv[1])
plan_id = sys.argv[2].strip()
reason = sys.argv[3].strip()
actor = sys.argv[4].strip() or "unknown"

if not re.fullmatch(r"PLAN-[A-Z0-9-]+", plan_id):
    raise SystemExit(f"FAIL: invalid plan_id: {plan_id}")

doc = yaml.safe_load(index_path.read_text(encoding="utf-8")) or {}
if not isinstance(doc, dict):
    raise SystemExit("FAIL: plans index must be YAML map")
plans = doc.get("plans")
if not isinstance(plans, list):
    raise SystemExit("FAIL: plans index key 'plans' must be a list")

found = False
previous_status = ""
for row in plans:
    if not isinstance(row, dict):
        continue
    if str(row.get("plan_id", "")).strip() != plan_id:
        continue
    found = True
    previous_status = str(row.get("status") or "").strip() or "deferred"
    if previous_status == "cancelled":
        previous_status = "canceled"

    if previous_status == "retired":
        raise SystemExit(f"FAIL: plan already retired: {plan_id}")
    if previous_status == "canceled":
        raise SystemExit(f"FAIL: cannot retire canceled plan: {plan_id}")
    if previous_status not in {"deferred", "promoted"}:
        raise SystemExit(
            f"FAIL: unsupported plan status transition {previous_status}->retired for {plan_id}"
        )

    row["status"] = "retired"
    row["retired_reason"] = reason
    row["retired_by"] = actor
    row["retired_from_status"] = previous_status
    row["retired_at_utc"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    break

if not found:
    raise SystemExit(f"FAIL: plan not found: {plan_id}")

doc["updated_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%d")
index_path.write_text(
    yaml.safe_dump(doc, sort_keys=False, allow_unicode=False),
    encoding="utf-8",
)

print("planning.plans.retire")
print(f"index: {index_path}")
print(f"plan_id: {plan_id}")
print(f"previous_status: {previous_status}")
print("status: retired")
PY
