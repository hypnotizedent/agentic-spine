#!/usr/bin/env bash
# media.e2e.verify — End-to-end media availability verification
#
# Usage (via spine):
#   ./bin/ops cap run media.e2e.verify
#   ./bin/ops cap run media.e2e.verify -- --mode sampled --sample-size 5
#   ./bin/ops cap run media.e2e.verify -- --mode targeted --ids 123,456
#   ./bin/ops cap run media.e2e.verify -- --json
#
# Contract:
# - Implements MEDIA_E2E_VERIFICATION_SPEC_V1
# - 4-leg check chain: arr_hasfile -> filesystem_exists -> jellyfin_indexed -> jellyseerr_fulfilled
# - Modes: targeted (specific IDs), sampled (random N), full_audit (all hasFile=true)
# - Verdict: AVAILABLE, DEGRADED, PARTIAL, UNAVAILABLE per item
#
# Spec ref: ops/bindings/media.e2e.verification.spec.yaml

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/../../../../" && pwd)"
SECRETS_EXEC="$ROOT/ops/plugins/secrets/bin/secrets-exec"
SSH_RESOLVE="$ROOT/ops/lib/ssh-resolve.sh"
GENERATED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

# Re-exec under secrets injection
if [[ -z "${SPINE_SECRETS_INJECTED:-}" ]]; then
  export SPINE_SECRETS_INJECTED=1
  exec "$SECRETS_EXEC" -- "$0" "$@"
fi

# shellcheck source=ops/lib/ssh-resolve.sh
source "$SSH_RESOLVE" 2>/dev/null || true

usage() {
  cat <<'USAGE'
media.e2e.verify — End-to-end media availability verification

Args:
  --mode MODE         targeted|sampled|full_audit (default: sampled)
  --ids IDS           Comma-separated Radarr movie IDs (for targeted mode)
  --sample-size N     Number of random titles to check (default: 10, for sampled mode)
  --json              Output JSON format

Examples:
  ./bin/ops cap run media.e2e.verify
  ./bin/ops cap run media.e2e.verify -- --mode targeted --ids 123,456,789
  ./bin/ops cap run media.e2e.verify -- --mode sampled --sample-size 5 --json
USAGE
}

MODE="sampled"
IDS=""
SAMPLE_SIZE=10
OUTPUT_JSON=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode)         MODE="${2:-sampled}"; shift 2 ;;
    --ids)          IDS="${2:-}"; shift 2 ;;
    --sample-size)  SAMPLE_SIZE="${2:-10}"; shift 2 ;;
    --json)         OUTPUT_JSON=true; shift ;;
    -h|--help)      usage; exit 0 ;;
    --)             shift ;;
    *)              echo "FAIL: unknown arg: $1" >&2; usage >&2; exit 1 ;;
  esac
done

command -v jq >/dev/null 2>&1 || { echo "MISSING_DEP: jq" >&2; exit 2; }
command -v curl >/dev/null 2>&1 || { echo "MISSING_DEP: curl" >&2; exit 2; }

# Resolve service endpoints
DOWNLOAD_HOST="${DOWNLOAD_HOST:-}"
STREAMING_HOST="${STREAMING_HOST:-}"
if [[ -z "$DOWNLOAD_HOST" ]]; then
  if type ssh_resolve_host_with_fallback &>/dev/null; then
    DOWNLOAD_HOST="$(ssh_resolve_host_with_fallback download-stack 2>/dev/null || echo "192.168.1.209")"
  else
    DOWNLOAD_HOST="192.168.1.209"
  fi
fi
if [[ -z "$STREAMING_HOST" ]]; then
  if type ssh_resolve_host_with_fallback &>/dev/null; then
    STREAMING_HOST="$(ssh_resolve_host_with_fallback streaming-stack 2>/dev/null || echo "192.168.1.210")"
  else
    STREAMING_HOST="192.168.1.210"
  fi
fi

RADARR_PORT="${RADARR_PORT:-7878}"
JELLYFIN_PORT="${JELLYFIN_PORT:-8096}"
JELLYSEERR_PORT="${JELLYSEERR_PORT:-5055}"

RADARR_URL="http://${DOWNLOAD_HOST}:${RADARR_PORT}"
JELLYFIN_URL="http://${STREAMING_HOST}:${JELLYFIN_PORT}"
JELLYSEERR_URL="http://${STREAMING_HOST}:${JELLYSEERR_PORT}"

# API keys from secrets injection
RADARR_API_KEY="${RADARR_API_KEY:-}"
JELLYFIN_API_KEY="${JELLYFIN_API_KEY:-}"
JELLYSEERR_API_KEY="${JELLYSEERR_API_KEY:-}"

if [[ -z "$RADARR_API_KEY" ]]; then
  echo "STOP: RADARR_API_KEY not available" >&2
  exit 2
fi

# Leg 1: Check Radarr hasFile
check_arr_hasfile() {
  local movie_id="$1"
  local result
  result="$(curl -sf --max-time 10 \
    -H "X-Api-Key: ${RADARR_API_KEY}" \
    "${RADARR_URL}/api/v3/movie/${movie_id}" 2>/dev/null)" || {
    echo '{"leg":"arr_hasfile","pass":false,"reason":"api_unreachable"}'
    return
  }
  local has_file title file_path tmdb_id
  has_file="$(echo "$result" | jq -r '.hasFile // false')"
  title="$(echo "$result" | jq -r '.title // "unknown"')"
  file_path="$(echo "$result" | jq -r '.movieFile.path // ""')"
  tmdb_id="$(echo "$result" | jq -r '.tmdbId // 0')"

  if [[ "$has_file" == "true" ]]; then
    jq -n --arg title "$title" --arg path "$file_path" --argjson tmdb "$tmdb_id" \
      '{leg: "arr_hasfile", pass: true, title: $title, file_path: $path, tmdb_id: $tmdb}'
  else
    jq -n --arg title "$title" --argjson tmdb "$tmdb_id" \
      '{leg: "arr_hasfile", pass: false, reason: "hasFile=false", title: $title, tmdb_id: $tmdb}'
  fi
}

# Leg 2: Check filesystem existence via SSH
check_filesystem_exists() {
  local file_path="$1"
  if [[ -z "$file_path" ]]; then
    echo '{"leg":"filesystem_exists","pass":false,"reason":"no_file_path"}'
    return
  fi
  local ssh_result
  ssh_result="$(ssh -o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null \
    "ubuntu@${DOWNLOAD_HOST}" "stat -c '%s' '${file_path}'" 2>/dev/null)" || {
    echo '{"leg":"filesystem_exists","pass":false,"reason":"ssh_unreachable_or_file_missing"}'
    return
  }
  if [[ -n "$ssh_result" ]] && [[ "$ssh_result" -gt 0 ]] 2>/dev/null; then
    jq -n --arg size "$ssh_result" '{leg: "filesystem_exists", pass: true, file_size_bytes: ($size | tonumber)}'
  else
    echo '{"leg":"filesystem_exists","pass":false,"reason":"file_empty_or_missing"}'
  fi
}

# Leg 3: Check Jellyfin library index
check_jellyfin_indexed() {
  local title="$1"
  local tmdb_id="$2"
  if [[ -z "$JELLYFIN_API_KEY" ]]; then
    echo '{"leg":"jellyfin_indexed","pass":false,"reason":"no_api_key"}'
    return
  fi
  local encoded_title
  encoded_title="$(python3 -c "import urllib.parse; print(urllib.parse.quote('$title'))" 2>/dev/null || echo "$title")"

  local result
  result="$(curl -sf --max-time 10 \
    -H "X-Emby-Token: ${JELLYFIN_API_KEY}" \
    "${JELLYFIN_URL}/Items?SearchTerm=${encoded_title}&IncludeItemTypes=Movie&Recursive=true&Fields=MediaSources,ProviderIds" 2>/dev/null)" || {
    echo '{"leg":"jellyfin_indexed","pass":false,"reason":"api_unreachable"}'
    return
  }

  local total_count
  total_count="$(echo "$result" | jq '.TotalRecordCount // 0')"
  if [[ "$total_count" -gt 0 ]]; then
    # Check for matching TMDb ID if available
    local match_found="false"
    if [[ "$tmdb_id" -gt 0 ]]; then
      match_found="$(echo "$result" | jq --argjson tmdb "$tmdb_id" \
        '[.Items[] | select(.ProviderIds.Tmdb == ($tmdb | tostring))] | length > 0')"
    else
      match_found="true"  # No TMDb to cross-ref, trust title match
    fi
    if [[ "$match_found" == "true" ]]; then
      jq -n --argjson count "$total_count" '{leg: "jellyfin_indexed", pass: true, matches: $count}'
    else
      jq -n --argjson count "$total_count" '{leg: "jellyfin_indexed", pass: false, reason: "title_match_but_no_tmdb_match", search_results: $count}'
    fi
  else
    echo '{"leg":"jellyfin_indexed","pass":false,"reason":"not_in_library"}'
  fi
}

# Leg 4: Check Jellyseerr request status (SKIP if no request exists)
check_jellyseerr_fulfilled() {
  local tmdb_id="$1"
  if [[ -z "$JELLYSEERR_API_KEY" ]] || [[ "$tmdb_id" -eq 0 ]]; then
    echo '{"leg":"jellyseerr_fulfilled","pass":true,"skip":true,"reason":"no_api_key_or_tmdb_id"}'
    return
  fi

  # Search for request by TMDb ID
  local result
  result="$(curl -sf --max-time 10 \
    -H "X-Api-Key: ${JELLYSEERR_API_KEY}" \
    "${JELLYSEERR_URL}/api/v1/request?take=20&skip=0" 2>/dev/null)" || {
    echo '{"leg":"jellyseerr_fulfilled","pass":true,"skip":true,"reason":"api_unreachable"}'
    return
  }

  # Find request matching this TMDb ID
  local matching_request
  matching_request="$(echo "$result" | jq --argjson tmdb "$tmdb_id" \
    '[.results[] | select(.media.tmdbId == $tmdb)] | first // null')"

  if [[ "$matching_request" == "null" ]]; then
    echo '{"leg":"jellyseerr_fulfilled","pass":true,"skip":true,"reason":"no_request_for_title"}'
    return
  fi

  local media_status
  media_status="$(echo "$matching_request" | jq '.media.status // 0')"
  # Status: 3=available, 4=partially_available, 5=processing
  if [[ "$media_status" -eq 3 ]] || [[ "$media_status" -eq 4 ]] || [[ "$media_status" -eq 5 ]]; then
    jq -n --argjson status "$media_status" '{leg: "jellyseerr_fulfilled", pass: true, media_status: $status}'
  else
    jq -n --argjson status "$media_status" '{leg: "jellyseerr_fulfilled", pass: false, reason: "not_available", media_status: $status}'
  fi
}

# Determine verdict from leg results
compute_verdict() {
  local legs_json="$1"
  echo "$legs_json" | jq '
    def severity_of(leg):
      if leg == "arr_hasfile" then "critical"
      elif leg == "filesystem_exists" then "critical"
      elif leg == "jellyfin_indexed" then "high"
      elif leg == "jellyseerr_fulfilled" then "medium"
      else "unknown"
      end;

    . as $legs |
    [.[] | select(.pass == false and (.skip // false) == false)] as $failures |
    if ($failures | length) == 0 then "AVAILABLE"
    elif [.[] | select(.pass == false and (.skip // false) == false) | .leg] | any(. == "arr_hasfile" or . == "filesystem_exists") then "UNAVAILABLE"
    elif [.[] | select(.pass == false and (.skip // false) == false) | .leg] | any(. == "jellyfin_indexed") then "DEGRADED"
    else "PARTIAL"
    end
  '
}

# Get movie IDs based on mode
get_movie_ids() {
  case "$MODE" in
    targeted)
      if [[ -z "$IDS" ]]; then
        echo "STOP: --ids required for targeted mode" >&2
        exit 1
      fi
      echo "$IDS" | tr ',' '\n'
      ;;
    sampled)
      # Get random sample of movies with hasFile=true
      local movies
      movies="$(curl -sf --max-time 30 \
        -H "X-Api-Key: ${RADARR_API_KEY}" \
        "${RADARR_URL}/api/v3/movie" 2>/dev/null)" || {
        echo "FAIL: cannot reach Radarr API" >&2
        exit 1
      }
      echo "$movies" | jq -r --argjson n "$SAMPLE_SIZE" \
        '[.[] | select(.hasFile == true) | .id] | if length > $n then [limit($n; .[])] else . end | .[]'
      ;;
    full_audit)
      local movies
      movies="$(curl -sf --max-time 60 \
        -H "X-Api-Key: ${RADARR_API_KEY}" \
        "${RADARR_URL}/api/v3/movie" 2>/dev/null)" || {
        echo "FAIL: cannot reach Radarr API" >&2
        exit 1
      }
      echo "$movies" | jq -r '[.[] | select(.hasFile == true) | .id] | .[]'
      ;;
    *)
      echo "STOP: invalid mode: $MODE" >&2
      exit 1
      ;;
  esac
}

# Run verification
MOVIE_IDS="$(get_movie_ids)" || exit $?

if [[ -z "$MOVIE_IDS" ]]; then
  if $OUTPUT_JSON; then
    jq -n --arg ts "$GENERATED_AT" --arg mode "$MODE" \
      '{capability: "media.e2e.verify", generated_at: $ts, mode: $mode, status: "empty", items: [], summary: {total: 0}}'
  else
    echo "media.e2e.verify: no items to check (mode=$MODE)"
  fi
  exit 0
fi

RESULTS="[]"
TOTAL=0
AVAILABLE=0
DEGRADED=0
PARTIAL=0
UNAVAILABLE=0

while IFS= read -r movie_id; do
  [[ -z "$movie_id" ]] && continue
  TOTAL=$((TOTAL + 1))

  # Leg 1: arr_hasfile
  leg1="$(check_arr_hasfile "$movie_id")"
  title="$(echo "$leg1" | jq -r '.title // "unknown"')"
  file_path="$(echo "$leg1" | jq -r '.file_path // ""')"
  tmdb_id="$(echo "$leg1" | jq -r '.tmdb_id // 0')"
  leg1_pass="$(echo "$leg1" | jq -r '.pass // false')"

  # Leg 2: filesystem_exists (only if leg 1 passed)
  if [[ "$leg1_pass" == "true" ]]; then
    leg2="$(check_filesystem_exists "$file_path")"
  else
    leg2='{"leg":"filesystem_exists","pass":false,"reason":"skipped_leg1_failed","skip":true}'
  fi

  # Leg 3: jellyfin_indexed
  leg3="$(check_jellyfin_indexed "$title" "$tmdb_id")"

  # Leg 4: jellyseerr_fulfilled
  leg4="$(check_jellyseerr_fulfilled "$tmdb_id")"

  # Compute verdict
  legs_json="$(jq -n --argjson l1 "$leg1" --argjson l2 "$leg2" --argjson l3 "$leg3" --argjson l4 "$leg4" '[$l1, $l2, $l3, $l4]')"
  verdict="$(compute_verdict "$legs_json")"

  case "$verdict" in
    '"AVAILABLE"')    AVAILABLE=$((AVAILABLE + 1)) ;;
    '"DEGRADED"')     DEGRADED=$((DEGRADED + 1)) ;;
    '"PARTIAL"')      PARTIAL=$((PARTIAL + 1)) ;;
    '"UNAVAILABLE"')  UNAVAILABLE=$((UNAVAILABLE + 1)) ;;
  esac

  item="$(jq -n --argjson mid "$movie_id" --arg title "$title" --argjson legs "$legs_json" --argjson verdict "$verdict" \
    '{movie_id: $mid, title: $title, legs: $legs, verdict: $verdict}')"
  RESULTS="$(echo "$RESULTS" | jq --argjson item "$item" '. + [$item]')"

done <<< "$MOVIE_IDS"

# Overall status
if [[ "$UNAVAILABLE" -gt 0 ]]; then
  OVERALL="fail"
elif [[ "$DEGRADED" -gt 0 ]] || [[ "$PARTIAL" -gt 0 ]]; then
  OVERALL="warn"
else
  OVERALL="pass"
fi

if $OUTPUT_JSON; then
  echo "$RESULTS" | jq \
    --arg ts "$GENERATED_AT" \
    --arg mode "$MODE" \
    --arg overall "$OVERALL" \
    --argjson total "$TOTAL" \
    --argjson avail "$AVAILABLE" \
    --argjson deg "$DEGRADED" \
    --argjson part "$PARTIAL" \
    --argjson unavail "$UNAVAILABLE" \
    '{
      capability: "media.e2e.verify",
      generated_at: $ts,
      mode: $mode,
      status: $overall,
      summary: {
        total: $total,
        available: $avail,
        degraded: $deg,
        partial: $part,
        unavailable: $unavail
      },
      items: .
    }'
else
  echo "media.e2e.verify"
  echo "================"
  echo "mode: $MODE"
  echo "status: $OVERALL"
  echo "generated_at: $GENERATED_AT"
  echo ""
  echo "Summary:"
  echo "  total:       $TOTAL"
  echo "  available:   $AVAILABLE"
  echo "  degraded:    $DEGRADED"
  echo "  partial:     $PARTIAL"
  echo "  unavailable: $UNAVAILABLE"
  echo ""

  # Show non-available items
  NON_AVAIL="$(echo "$RESULTS" | jq -r '.[] | select(.verdict != "AVAILABLE") | "  \(.verdict) \(.title) (id=\(.movie_id))"')"
  if [[ -n "$NON_AVAIL" ]]; then
    echo "Non-Available Items:"
    echo "$NON_AVAIL"
  fi
fi

if [[ "$OVERALL" == "fail" ]]; then
  exit 1
fi
exit 0
