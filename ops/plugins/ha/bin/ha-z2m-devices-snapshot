#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SPINE_ROOT="${SPINE_ROOT:-$(cd "$SCRIPT_DIR/../../../.." && pwd)}"
SCRIPT_NAME="$(basename "$0")"
PROJECT_ROOT="${HA_PLUGIN_PROJECT_ROOT:-/Users/ronnyworks/code/workbench/agents/home-assistant/docs/spine-plugin-ha/bin}"
PROJECT_SCRIPT="$PROJECT_ROOT/$SCRIPT_NAME"
LEGACY_SCRIPT="$SCRIPT_DIR/${SCRIPT_NAME}.legacy"
FORCE_LOCAL="${SPINE_SNAPSHOT_FORCE_LOCAL:-1}"

# Snapshot hardening contract: default to repo-local writer so read-mode
# no-write guards are always enforced in this checkout.
if [[ "$FORCE_LOCAL" == "1" ]]; then
  exec env SPINE_ROOT="$SPINE_ROOT" "$LEGACY_SCRIPT" "$@"
fi

if [[ -x "$PROJECT_SCRIPT" ]]; then
  exec env SPINE_ROOT="$SPINE_ROOT" "$PROJECT_SCRIPT" "$@"
fi

echo "WARN: ha plugin fallback active; delegated project command missing at $PROJECT_SCRIPT" >&2
exec "$LEGACY_SCRIPT" "$@"
