#!/usr/bin/env bash
set -euo pipefail

SPINE_ROOT="${SPINE_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)}"
RONNY_PRODUCTS_ROOT="${RONNY_PRODUCTS_ROOT:-$HOME/code/ronny-products}"
APP_ROOT="$RONNY_PRODUCTS_ROOT/cc-benefits-tracker"
TRACKER="$APP_ROOT/scripts/run-tracker.sh"

CARDS_PATH="$APP_ROOT/schema/cards.catalog.json"
STATE_PATH="$APP_ROOT/schema/state.sample.json"
OUTPUT_ROOT="$SPINE_ROOT/runtime/domain-state/finance/cc-benefits-tracker"
AS_OF=""
DRY_RUN=0

usage() {
  cat <<'USAGE'
finance-cc-benefits-refresh

Usage:
  finance-cc-benefits-refresh [--cards <path>] [--state <path>] [--as-of YYYY-MM-DD] [--output-root <dir>] [--dry-run]

Mutating refresh: computes deterministic status report and reminder queue artifacts.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --cards) CARDS_PATH="${2:?--cards requires value}"; shift 2 ;;
    --state) STATE_PATH="${2:?--state requires value}"; shift 2 ;;
    --as-of) AS_OF="${2:?--as-of requires value}"; shift 2 ;;
    --output-root) OUTPUT_ROOT="${2:?--output-root requires value}"; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage; exit 2 ;;
  esac
done

[[ -x "$TRACKER" ]] || { echo "ERROR: tracker entrypoint not found: $TRACKER" >&2; exit 1; }
[[ -f "$CARDS_PATH" ]] || { echo "ERROR: cards catalog missing: $CARDS_PATH" >&2; exit 1; }

REPORT_PATH="$OUTPUT_ROOT/status-report.json"
QUEUE_PATH="$OUTPUT_ROOT/reminder-queue.json"

cmd=("$TRACKER" --cards "$CARDS_PATH" --mode apply --report-out "$REPORT_PATH" --queue-out "$QUEUE_PATH" --quiet)
if [[ -f "$STATE_PATH" ]]; then
  cmd+=(--state "$STATE_PATH")
fi
if [[ -n "$AS_OF" ]]; then
  cmd+=(--as-of "$AS_OF")
fi

if [[ "$DRY_RUN" -eq 1 ]]; then
  echo "finance.cc_benefits.refresh"
  echo "mode: dry-run"
  echo "cards: $CARDS_PATH"
  if [[ -f "$STATE_PATH" ]]; then
    echo "state: $STATE_PATH"
  else
    echo "state: <none>"
  fi
  echo "report_path: $REPORT_PATH"
  echo "queue_path: $QUEUE_PATH"
  dry_cmd=("$TRACKER" --cards "$CARDS_PATH" --mode dry-run --quiet)
  if [[ -f "$STATE_PATH" ]]; then
    dry_cmd+=(--state "$STATE_PATH")
  fi
  if [[ -n "$AS_OF" ]]; then
    dry_cmd+=(--as-of "$AS_OF")
  fi
  exec "${dry_cmd[@]}"
fi

mkdir -p "$OUTPUT_ROOT"
"${cmd[@]}"
