#!/usr/bin/env bash
# finance-stack-status - Health + API status for all finance services on VM 211
#
# Probes: Firefly III, Paperless-ngx, Ghostfolio (optional), Mail Archiver
# Host: finance-stack (VM 211, Tailscale 192.168.1.211)
# Secrets: FIREFLY_PAT and PAPERLESS_API_TOKEN via infisical-agent.sh.
# Ghostfolio runtime proof is host-local public info; portfolio reads remain a
# separate optional surface.
#
# Usage:
#   finance-stack-status

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SPINE_ROOT="${SPINE_ROOT:-$(cd "$SCRIPT_DIR/../../../.." && pwd)}"
INFISICAL_AGENT="${SPINE_ROOT}/ops/tools/infisical-agent.sh"

# Resolve host via binding with LAN→Tailscale fallback
source "${SPINE_ROOT}/ops/lib/ssh-resolve.sh"
_resolve_result="$(ssh_resolve_host_with_fallback "finance-stack" 2)" || true
HOST_IP="$(echo "$_resolve_result" | awk '{print $1}')"
_PATH_USED="$(echo "$_resolve_result" | awk '{print $2}')"
[[ -z "$HOST_IP" ]] && HOST_IP="192.168.1.211"

CONNECT_TIMEOUT=5
MAX_TIME=10

stop(){ echo "STOP (2): $*" >&2; exit 2; }

command -v curl >/dev/null 2>&1 || stop "missing dependency: curl"
command -v jq >/dev/null 2>&1  || stop "missing dependency: jq"

# ── Fetch auth tokens (best-effort, non-fatal) ──────────────────────────
FIREFLY_TOKEN=""
PAPERLESS_TOKEN=""

if [[ -x "$INFISICAL_AGENT" ]]; then
  FIREFLY_TOKEN=$("$INFISICAL_AGENT" get infrastructure prod FIREFLY_PAT 2>/dev/null) || FIREFLY_TOKEN=""
  PAPERLESS_TOKEN=$("$INFISICAL_AGENT" get infrastructure prod PAPERLESS_API_TOKEN 2>/dev/null) || PAPERLESS_TOKEN=""
fi

# Resolve mail-archiver host (on communications-stack VM 214, not finance-stack)
_ma_result="$(ssh_resolve_host_with_fallback "communications-stack" 2)" || true
_MA_IP="$(echo "$_ma_result" | awk '{print $1}')"
[[ -z "$_MA_IP" ]] && _MA_IP="192.168.1.26"

# ── Service definitions ─────────────────────────────────────────────────
# name|url|expected_code|service_tier
SERVICES=(
  "firefly-iii|http://${HOST_IP}:8090/api/v1/about|200|required"
  "paperless-ngx|http://${HOST_IP}:8000/api/documents/?page_size=1|200|required"
  "ghostfolio|http://${HOST_IP}:3340/api/v1/info|200|optional"
  "mail-archiver|http://${_MA_IP}:5100/|302|required"
)

# ── Probe helper ────────────────────────────────────────────────────────
probe_http() {
  local url="$1"
  local extra_header="${2:-}"
  local args=(-s -o /dev/null -w "%{http_code}" --connect-timeout "$CONNECT_TIMEOUT" --max-time "$MAX_TIME" --max-redirs 0)
  if [[ -n "$extra_header" ]]; then
    args+=(-H "$extra_header")
  fi
  curl "${args[@]}" "$url" 2>/dev/null || echo "000"
}

# Fetch JSON body (for API detail calls)
fetch_json() {
  local url="$1"
  local auth_header="$2"
  curl -s --connect-timeout "$CONNECT_TIMEOUT" --max-time "$MAX_TIME" \
    -H "$auth_header" -H "Accept: application/json" "$url" 2>/dev/null || echo ""
}

# ── Main output ─────────────────────────────────────────────────────────
echo "finance.stack.status"
echo "host: finance-stack (VM 211, ${HOST_IP}, path=${_PATH_USED})"
echo

pass=0
fail=0
warn=0
required_total=0

for entry in "${SERVICES[@]}"; do
  IFS='|' read -r name url expect service_tier <<< "$entry"
  detail=""
  status_kind="healthy"

  if [[ "$service_tier" == "required" ]]; then
    required_total=$((required_total + 1))
  fi

  # Health probe
  http_code=$(probe_http "$url")

  # Service-specific API enrichment
  case "$name" in
    firefly-iii)
      if [[ "$http_code" != "$expect" && -n "$FIREFLY_TOKEN" ]]; then
        auth_code=$(probe_http "$url" "Authorization: Bearer ${FIREFLY_TOKEN}")
        if [[ "$auth_code" == "200" ]]; then
          http_code="200"
        fi
      fi
      if [[ -n "$FIREFLY_TOKEN" ]]; then
        about_json=$(fetch_json "http://${HOST_IP}:8090/api/v1/about" "Authorization: Bearer ${FIREFLY_TOKEN}")
        if [[ -n "$about_json" ]]; then
          version=$(echo "$about_json" | jq -r '.data.version // empty' 2>/dev/null || true)
          if [[ -n "$version" ]]; then
            detail="version ${version}"
          fi
        fi
        txn_list=$(fetch_json "http://${HOST_IP}:8090/api/v1/transactions?limit=1" "Authorization: Bearer ${FIREFLY_TOKEN}")
        if [[ -n "$txn_list" ]]; then
          txn_total=$(echo "$txn_list" | jq -r '.meta.pagination.total // empty' 2>/dev/null || true)
          if [[ -n "$txn_total" ]]; then
            if [[ -n "$detail" ]]; then
              detail="${detail}, ${txn_total} transactions"
            else
              detail="${txn_total} transactions"
            fi
          fi
        fi
      fi
      ;;
    paperless-ngx)
      if [[ -n "$PAPERLESS_TOKEN" ]]; then
        auth_code=$(probe_http "$url" "Authorization: Token ${PAPERLESS_TOKEN}")
        if [[ "$auth_code" == "200" ]]; then
          http_code="200"
        fi
        doc_json=$(fetch_json "http://${HOST_IP}:8000/api/documents/?page_size=1" "Authorization: Token ${PAPERLESS_TOKEN}")
        if [[ -n "$doc_json" ]]; then
          doc_count=$(echo "$doc_json" | jq -r '.count // empty' 2>/dev/null || true)
          if [[ -n "$doc_count" ]]; then
            detail="${doc_count} documents"
          fi
        fi
      fi
      ;;
    ghostfolio)
      ghostfolio_info=$(curl -s --connect-timeout "$CONNECT_TIMEOUT" --max-time "$MAX_TIME" \
        -H "Accept: application/json" \
        "http://${HOST_IP}:3340/api/v1/info" 2>/dev/null || echo "")
      if [[ -n "$ghostfolio_info" ]]; then
        ghostfolio_version=$(echo "$ghostfolio_info" | jq -r '.version // empty' 2>/dev/null || true)
        detail="optional investment tracking"
        if [[ -n "$ghostfolio_version" ]]; then
          detail="${detail}, version ${ghostfolio_version}"
        fi
      else
        detail="optional investment tracking, public info unavailable"
        status_kind="warn"
      fi
      ;;
  esac

  # Determine health: expected code or 200 (authenticated upgrade)
  is_healthy="false"
  if [[ "$http_code" == "$expect" || "$http_code" == "200" ]]; then
    is_healthy="true"
  fi

  status_parts="HTTP ${http_code}"
  if [[ -n "$detail" ]]; then
    status_parts="${status_parts}, ${detail}"
  fi

  if [[ "$service_tier" == "optional" ]]; then
    if [[ "$is_healthy" == "true" && "$status_kind" == "healthy" ]]; then
      printf "  %-20s ~ OPT  (%s)\n" "$name" "$status_parts"
    else
      printf "  %-20s ! WARN (%s)\n" "$name" "$status_parts"
      warn=$((warn + 1))
    fi
  elif [[ "$is_healthy" == "true" ]]; then
    printf "  %-20s ✓ UP   (%s)\n" "$name" "$status_parts"
    pass=$((pass + 1))
  else
    printf "  %-20s ✗ DOWN (%s, expected %s)\n" "$name" "HTTP ${http_code}" "$expect"
    fail=$((fail + 1))
  fi
done

echo
echo "summary: core=${pass}/${required_total} healthy, optional_warn=${warn}"

if [[ $fail -gt 0 ]]; then
  echo "status: DEGRADED"
  exit 1
else
  echo "status: OK"
fi
