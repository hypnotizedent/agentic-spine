#!/usr/bin/env bash
set -euo pipefail

ROOT="${SPINE_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)}"
REGISTRY="$ROOT/ops/bindings/gate.registry.yaml"
TOPOLOGY_VALIDATE="$ROOT/ops/plugins/verify/bin/gate-topology-validate"
ENTRY_METADATA_GENERATOR="$ROOT/bin/generators/gen-entry-surface-gate-metadata.sh"
HEADER_GENERATOR="$ROOT/bin/generators/gen-gate-registry-header.sh"
AGENTS_SURFACE="$ROOT/AGENTS.md"
CLAUDE_SURFACE="$ROOT/CLAUDE.md"
ENTRY_METADATA_FILE="$ROOT/docs/governance/generated/ENTRY_SURFACE_GATE_METADATA.md"

source "$ROOT/ops/lib/git-lock.sh"
source "$ROOT/ops/lib/governed-write-transaction.sh"

usage() {
  cat <<'USAGE'
gate-registry-update

Usage:
  gate-registry-update --gate-id <DNN> --field <field_name> --value <value>

Supported fields:
  name, category, description, severity, check_script, fix_hint,
  inline, retired, warn_only, verbose_only, composite_parent,
  ring, mode, gate_class
USAGE
}

fail() {
  echo "gate.registry.update FAIL: $*" >&2
  exit 1
}

cleanup() {
  release_git_lock || true
  spine_tx_cleanup
  return 0
}

print_d128_trailers() {
  echo "D128 required commit trailers:"
  echo "Gate-Mutation: capability"
  echo "Gate-Capability: gate.registry.update"
  echo "Gate-Run-Key: ${SPINE_CAP_RUN_KEY:-manual}"
}

[[ -f "$REGISTRY" ]] || fail "missing registry: $REGISTRY"
command -v yq >/dev/null 2>&1 || fail "missing required tool: yq"
[[ -x "$TOPOLOGY_VALIDATE" ]] || fail "missing validator: $TOPOLOGY_VALIDATE"
[[ -x "$ENTRY_METADATA_GENERATOR" ]] || fail "missing generator: $ENTRY_METADATA_GENERATOR"
[[ -x "$HEADER_GENERATOR" ]] || fail "missing generator: $HEADER_GENERATOR"

GATE_ID=""
FIELD=""
VALUE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --gate-id) GATE_ID="${2:-}"; shift 2 ;;
    --field) FIELD="${2:-}"; shift 2 ;;
    --value) VALUE="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) fail "unknown argument: $1" ;;
  esac
done

[[ -n "$GATE_ID" ]] || fail "--gate-id is required"
[[ -n "$FIELD" ]] || fail "--field is required"

exists="$(yq e -r ".gates[] | select(.id == \"$GATE_ID\") | .id" "$REGISTRY" | head -n1 || true)"
[[ -n "$exists" ]] || fail "gate '$GATE_ID' not found"

case "$FIELD" in
  inline|retired|warn_only|verbose_only)
    [[ "$VALUE" == "true" || "$VALUE" == "false" ]] || fail "field '$FIELD' requires boolean value true|false"
    ;;
  severity)
    [[ "$VALUE" =~ ^(low|medium|high|critical)$ ]] || fail "field '$FIELD' requires low|medium|high|critical"
    ;;
  ring)
    [[ "$VALUE" =~ ^(instant|standard|deep)$ ]] || fail "field '$FIELD' requires instant|standard|deep"
    ;;
  mode)
    [[ "$VALUE" =~ ^(enforce|report)$ ]] || fail "field '$FIELD' requires enforce|report"
    ;;
  gate_class)
    [[ "$VALUE" =~ ^(invariant|parity|freshness|observational|advisory)$ ]] || fail "field '$FIELD' requires invariant|parity|freshness|observational|advisory"
    ;;
  name|category|description|check_script|fix_hint|composite_parent)
    ;;
  *)
    fail "unsupported field: $FIELD"
    ;;
esac

acquire_git_lock gate_registry || exit 1
trap cleanup EXIT INT TERM
spine_tx_init
spine_tx_track "$REGISTRY"
spine_tx_track "$AGENTS_SURFACE"
spine_tx_track "$CLAUDE_SURFACE"
spine_tx_track "$ENTRY_METADATA_FILE"

export FIELD VALUE GATE_ID
STAMP="$(date +%Y-%m-%d)"

if ! {
  case "$FIELD" in
    inline|retired|warn_only|verbose_only)
      yq -i "(.gates[] | select(.id == strenv(GATE_ID))).${FIELD} = (strenv(VALUE) == \"true\")" "$REGISTRY"
      ;;
    name|category|description|severity|check_script|fix_hint|composite_parent|ring|mode|gate_class)
      yq -i "(.gates[] | select(.id == strenv(GATE_ID))).${FIELD} = strenv(VALUE)" "$REGISTRY"
      ;;
  esac

  yq -i ".updated = \"$STAMP\"" "$REGISTRY"
  "$HEADER_GENERATOR" >/dev/null
  "$ENTRY_METADATA_GENERATOR" --write-surfaces >/dev/null
  "$TOPOLOGY_VALIDATE" >/dev/null
}; then
  spine_tx_rollback
  fail "write transaction rolled back"
fi

total="$(yq e '.gate_count.total' "$REGISTRY")"
retired="$(yq e '.gate_count.retired' "$REGISTRY")"
active="$(yq e '.gate_count.active' "$REGISTRY")"

echo "gate.registry.update PASS: $GATE_ID.$FIELD updated (total=$total active=$active retired=$retired)"
print_d128_trailers
