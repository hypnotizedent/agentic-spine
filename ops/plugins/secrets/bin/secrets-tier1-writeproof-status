#!/usr/bin/env python3
import argparse
import json
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


ROOT = Path(__file__).resolve().parents[4]
CONTRACT = ROOT / "ops/bindings/secrets.tier1.writeproof.contract.yaml"
CAPABILITY = "secrets.tier1.writeproof.status"


def stop(message: str, code: int = 2) -> int:
    print(f"STOP: {message}", file=sys.stderr)
    return code


def load_contract() -> dict:
    result = subprocess.run(
        ["yq", "-o=json", ".", str(CONTRACT)],
        cwd=ROOT,
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or "failed to parse contract with yq")
    return json.loads(result.stdout)


def run_helper(script_rel: str) -> tuple[dict, int, str]:
    script_path = ROOT / script_rel
    result = subprocess.run(
        [str(script_path), "--json"],
        cwd=ROOT,
        capture_output=True,
        text=True,
        check=False,
    )
    stderr = result.stderr.strip()
    stdout = result.stdout.strip()
    if not stdout:
        payload = {
            "status": "fail",
            "proven": False,
            "reason": "helper emitted no stdout",
        }
        return payload, result.returncode or 1, stderr
    try:
        payload = json.loads(stdout)
    except json.JSONDecodeError as exc:
        payload = {
            "status": "fail",
            "proven": False,
            "reason": f"helper emitted invalid JSON: {exc}",
            "raw_stdout": stdout[:500],
        }
    return payload, result.returncode, stderr


def summarize(rows: list[dict]) -> tuple[str, dict]:
    live_safe = [row for row in rows if row.get("proof_mode") == "live_safe"]
    manual_only = [row for row in rows if row.get("proof_mode") == "manual_only"]
    live_safe_passed = sum(1 for row in live_safe if row.get("proven") is True and row.get("status") == "pass")
    live_safe_failed = len(live_safe) - live_safe_passed
    summary = {
        "total": len(rows),
        "live_safe_total": len(live_safe),
        "live_safe_passed": live_safe_passed,
        "live_safe_failed": live_safe_failed,
        "manual_only_total": len(manual_only),
    }
    if live_safe_failed:
        status = "fail"
    elif manual_only:
        status = "pass_with_manual_gaps"
    else:
        status = "pass"
    return status, summary


def render_text(status: str, summary: dict, rows: list[dict]) -> None:
    print(CAPABILITY)
    print(f"contract: {CONTRACT}")
    print(f"status: {status}")
    print(f"live_safe: {summary['live_safe_passed']}/{summary['live_safe_total']} proven")
    print(f"manual_only: {summary['manual_only_total']}")
    print()
    print(f"{'integration':16} {'mode':12} {'status':20} {'reason'}")
    print(f"{'-' * 16} {'-' * 12} {'-' * 20} {'-' * 48}")
    for row in rows:
        integration = row.get("integration", "unknown")
        mode = row.get("proof_mode", "unknown")
        row_status = row.get("status", "unknown")
        reason = row.get("reason", "") or row.get("note", "")
        if len(reason) > 96:
            reason = reason[:93] + "..."
        print(f"{integration:16} {mode:12} {row_status:20} {reason}")


def main() -> int:
    parser = argparse.ArgumentParser(description="Run tier-1 Infisical integration write proofs.")
    parser.add_argument("--json", action="store_true", help="Emit JSON output")
    parser.add_argument("--integration", help="Run only one integration from the tier-1 contract")
    args = parser.parse_args()

    if not CONTRACT.exists():
        return stop(f"missing contract: {CONTRACT}")

    try:
        contract = load_contract()
    except Exception as exc:
        return stop(str(exc))

    integrations = contract.get("integrations") if isinstance(contract.get("integrations"), dict) else {}
    if not integrations:
        return stop("contract integrations block is missing or empty")

    rows: list[dict] = []
    selected_items = integrations.items()
    if args.integration:
        if args.integration not in integrations:
            return stop(f"unknown integration: {args.integration}", code=1)
        selected_items = [(args.integration, integrations[args.integration])]

    for integration_id, entry in selected_items:
        proof_mode = str(entry.get("proof_mode", "")).strip()
        secret_keys = entry.get("secret_keys") if isinstance(entry.get("secret_keys"), list) else []
        rationale = str(entry.get("rationale", "")).strip()
        authority_refs = entry.get("authority_refs") if isinstance(entry.get("authority_refs"), list) else []

        if proof_mode == "live_safe":
            helper = str(entry.get("helper_script", "")).strip()
            if not helper:
                row = {
                    "integration": integration_id,
                    "proof_mode": proof_mode,
                    "status": "fail",
                    "proven": False,
                    "reason": "helper_script missing from contract",
                }
            else:
                payload, returncode, stderr = run_helper(helper)
                row = {
                    "integration": integration_id,
                    "proof_mode": proof_mode,
                    "secret_keys": secret_keys,
                    "authority_refs": authority_refs,
                    "rationale": rationale,
                    "helper_script": helper,
                    **payload,
                }
                row["returncode"] = returncode
                if stderr:
                    row["stderr"] = stderr[:500]
                if returncode != 0 and row.get("status") == "pass":
                    row["status"] = "fail"
                    row["proven"] = False
                    row["reason"] = f"helper returned non-zero exit code {returncode}"
        elif proof_mode == "manual_only":
            row = {
                "integration": integration_id,
                "proof_mode": proof_mode,
                "status": "manual_only",
                "proven": False,
                "reason": rationale,
                "secret_keys": secret_keys,
                "authority_refs": authority_refs,
            }
        else:
            row = {
                "integration": integration_id,
                "proof_mode": proof_mode or "unknown",
                "status": "fail",
                "proven": False,
                "reason": f"unsupported proof_mode in contract: {proof_mode or 'missing'}",
                "secret_keys": secret_keys,
                "authority_refs": authority_refs,
            }
        rows.append(row)

    status, summary = summarize(rows)
    payload = {
        "capability": CAPABILITY,
        "status": status,
        "generated_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "summary": summary,
        "integrations": rows,
    }

    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        render_text(status, summary, rows)

    return 0 if summary["live_safe_failed"] == 0 else 1


if __name__ == "__main__":
    sys.exit(main())
