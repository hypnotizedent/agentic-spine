#!/usr/bin/env bash
set -euo pipefail

ROOT="${SPINE_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)}"
SECRETS_EXEC="$ROOT/ops/plugins/secrets/bin/secrets-exec"

if [[ -z "${SPINE_SECRETS_INJECTED:-}" ]]; then
  export SPINE_SECRETS_INJECTED=1
  exec "$SECRETS_EXEC" -- "$0" "$@"
fi

JSON_OUT=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) JSON_OUT=1; shift ;;
    --) shift ;;
    *) shift ;;
  esac
done

TAILNET="${TAILSCALE_TAILNET:-taile9480.ts.net}"
API_BASE="https://api.tailscale.com/api/v2"
STATUS="fail"
REASON=""
RC=1
PROVEN=false
OAUTH_HTTP_CODE=""
READ_HTTP_CODE=""
WRITE_HTTP_CODE=""
ETAG_PRESENT=false
ERROR_SNIPPET=""
NOTE="reapplied current live ACL body unchanged"

finish() {
  if [[ "$JSON_OUT" -eq 1 ]]; then
    STATUS="$STATUS" \
    REASON="$REASON" \
    PROVEN="$PROVEN" \
    TAILNET="$TAILNET" \
    OAUTH_HTTP_CODE="$OAUTH_HTTP_CODE" \
    READ_HTTP_CODE="$READ_HTTP_CODE" \
    WRITE_HTTP_CODE="$WRITE_HTTP_CODE" \
    ETAG_PRESENT="$ETAG_PRESENT" \
    ERROR_SNIPPET="$ERROR_SNIPPET" \
    NOTE="$NOTE" \
    python3 - <<'PY'
import json, os
print(json.dumps({
    "integration": "tailscale",
    "proof_mode": "live_safe",
    "status": os.environ["STATUS"],
    "proven": os.environ["PROVEN"].lower() == "true",
    "reason": os.environ["REASON"],
    "tailnet": os.environ["TAILNET"],
    "oauth_http_code": os.environ["OAUTH_HTTP_CODE"] or None,
    "read_http_code": os.environ["READ_HTTP_CODE"] or None,
    "write_http_code": os.environ["WRITE_HTTP_CODE"] or None,
    "etag_present": os.environ["ETAG_PRESENT"].lower() == "true",
    "note": os.environ["NOTE"],
    "error_snippet": os.environ["ERROR_SNIPPET"] or None,
}, indent=2))
PY
  else
    echo "integration: tailscale"
    echo "status: $STATUS"
    echo "proven: $PROVEN"
    echo "tailnet: $TAILNET"
    echo "oauth_http_code: ${OAUTH_HTTP_CODE:-n/a}"
    echo "read_http_code: ${READ_HTTP_CODE:-n/a}"
    echo "write_http_code: ${WRITE_HTTP_CODE:-n/a}"
    echo "etag_present: $ETAG_PRESENT"
    echo "reason: ${REASON:-$NOTE}"
    [[ -n "$ERROR_SNIPPET" ]] && echo "error: $ERROR_SNIPPET"
  fi
  exit "$RC"
}

cleanup_files=()
cleanup() {
  local f
  for f in "${cleanup_files[@]:-}"; do
    [[ -n "$f" ]] && rm -f "$f"
  done
}
trap cleanup EXIT

command -v curl >/dev/null 2>&1 || { STATUS="stop"; REASON="missing dependency: curl"; RC=2; finish; }
command -v python3 >/dev/null 2>&1 || { STATUS="stop"; REASON="missing dependency: python3"; RC=2; finish; }

[[ -n "${TAILSCALE_OAUTH_CLIENT_ID:-}" ]] || { STATUS="stop"; REASON="missing TAILSCALE_OAUTH_CLIENT_ID"; RC=2; finish; }
[[ -n "${TAILSCALE_OAUTH_CLIENT_SECRET:-}" ]] || { STATUS="stop"; REASON="missing TAILSCALE_OAUTH_CLIENT_SECRET"; RC=2; finish; }

token_body="$(mktemp)"; cleanup_files+=("$token_body")
token_err="$(mktemp)"; cleanup_files+=("$token_err")
if ! OAUTH_HTTP_CODE="$(curl -sS -o "$token_body" -w '%{http_code}' \
  -X POST \
  -u "${TAILSCALE_OAUTH_CLIENT_ID}:${TAILSCALE_OAUTH_CLIENT_SECRET}" \
  -d "grant_type=client_credentials" \
  "https://api.tailscale.com/api/v2/oauth/token" \
  2>"$token_err")"; then
  STATUS="fail"
  REASON="oauth token exchange failed"
  ERROR_SNIPPET="$(tr '\n' ' ' <"$token_err" | cut -c1-240)"
  finish
fi

if [[ "$OAUTH_HTTP_CODE" != "200" ]]; then
  STATUS="fail"
  REASON="oauth token exchange returned non-200"
  ERROR_SNIPPET="$(tr -d '\n' <"$token_body" | cut -c1-240)"
  finish
fi

BEARER="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get("access_token",""))' "$token_body" 2>/dev/null || true)"
[[ -n "$BEARER" ]] || { STATUS="fail"; REASON="oauth response missing access_token"; ERROR_SNIPPET="$(tr -d '\n' <"$token_body" | cut -c1-240)"; finish; }

read_headers="$(mktemp)"; cleanup_files+=("$read_headers")
read_body="$(mktemp)"; cleanup_files+=("$read_body")
read_err="$(mktemp)"; cleanup_files+=("$read_err")
if ! READ_HTTP_CODE="$(curl -sS -D "$read_headers" -o "$read_body" -w '%{http_code}' \
  -H "Authorization: Bearer $BEARER" \
  -H "Accept: application/hujson" \
  "${API_BASE}/tailnet/${TAILNET}/acl" \
  2>"$read_err")"; then
  STATUS="fail"
  REASON="failed to fetch live ACL"
  ERROR_SNIPPET="$(tr '\n' ' ' <"$read_err" | cut -c1-240)"
  finish
fi

if [[ ! "$READ_HTTP_CODE" =~ ^2 ]]; then
  STATUS="fail"
  REASON="live ACL fetch returned non-2xx"
  ERROR_SNIPPET="$(tr -d '\n' <"$read_body" | cut -c1-240)"
  finish
fi

if [[ ! -s "$read_body" ]]; then
  STATUS="fail"
  REASON="live ACL body was empty"
  finish
fi

ETAG="$(grep -i '^etag:' "$read_headers" 2>/dev/null | sed 's/^[Ee][Tt][Aa][Gg]: *//;s/\r$//' || true)"
[[ -n "$ETAG" ]] && ETAG_PRESENT=true

write_body="$(mktemp)"; cleanup_files+=("$write_body")
write_err="$(mktemp)"; cleanup_files+=("$write_err")
curl_args=(
  -sS
  -o "$write_body"
  -w '%{http_code}'
  -X POST
  -H "Authorization: Bearer $BEARER"
  -H "Content-Type: application/hujson"
  --data-binary "@$read_body"
  "${API_BASE}/tailnet/${TAILNET}/acl"
)
if [[ -n "$ETAG" ]]; then
  curl_args=(-sS -o "$write_body" -w '%{http_code}' -X POST -H "Authorization: Bearer $BEARER" -H "Content-Type: application/hujson" -H "If-Match: $ETAG" --data-binary "@$read_body" "${API_BASE}/tailnet/${TAILNET}/acl")
fi
if ! WRITE_HTTP_CODE="$(curl "${curl_args[@]}" 2>"$write_err")"; then
  STATUS="fail"
  REASON="live ACL reapply request failed"
  ERROR_SNIPPET="$(tr '\n' ' ' <"$write_err" | cut -c1-240)"
  finish
fi

if [[ ! "$WRITE_HTTP_CODE" =~ ^2 ]]; then
  STATUS="fail"
  REASON="live ACL reapply returned non-2xx"
  ERROR_SNIPPET="$(tr -d '\n' <"$write_body" | cut -c1-240)"
  finish
fi

STATUS="pass"
PROVEN=true
RC=0
finish
