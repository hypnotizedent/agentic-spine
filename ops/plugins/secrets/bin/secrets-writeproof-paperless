#!/usr/bin/env bash
set -euo pipefail

ROOT="${SPINE_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)}"
SECRETS_EXEC="$ROOT/ops/plugins/secrets/bin/secrets-exec"
INFISICAL_AGENT="$ROOT/ops/tools/infisical-agent.sh"
source "$ROOT/ops/lib/ssh-resolve.sh"

if [[ -z "${SPINE_SECRETS_INJECTED:-}" ]]; then
  export SPINE_SECRETS_INJECTED=1
  exec "$SECRETS_EXEC" -- "$0" "$@"
fi

JSON_OUT=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) JSON_OUT=1; shift ;;
    --) shift ;;
    *) shift ;;
  esac
done

STATUS="fail"
REASON=""
RC=1
PROVEN=false
CREATE_HTTP_CODE=""
DELETE_HTTP_CODE=""
ERROR_SNIPPET=""
BASE_URL=""
RESOLVED_HOST=""
PATH_USED=""
TAG_NAME="spine-writeproof-$(date -u +%Y%m%d%H%M%S)-$$"
TAG_ID=""
CREATED=0

finish() {
  if [[ "$JSON_OUT" -eq 1 ]]; then
    STATUS="$STATUS" \
    REASON="$REASON" \
    PROVEN="$PROVEN" \
    CREATE_HTTP_CODE="$CREATE_HTTP_CODE" \
    DELETE_HTTP_CODE="$DELETE_HTTP_CODE" \
    ERROR_SNIPPET="$ERROR_SNIPPET" \
    BASE_URL="$BASE_URL" \
    RESOLVED_HOST="$RESOLVED_HOST" \
    PATH_USED="$PATH_USED" \
    TAG_NAME="$TAG_NAME" \
    TAG_ID="$TAG_ID" \
    python3 - <<'PY'
import json, os
print(json.dumps({
    "integration": "paperless",
    "proof_mode": "live_safe",
    "status": os.environ["STATUS"],
    "proven": os.environ["PROVEN"].lower() == "true",
    "reason": os.environ["REASON"],
    "base_url": os.environ["BASE_URL"] or None,
    "resolved_host": os.environ["RESOLVED_HOST"] or None,
    "path_used": os.environ["PATH_USED"] or None,
    "tag_name": os.environ["TAG_NAME"],
    "tag_id": os.environ["TAG_ID"] or None,
    "create_http_code": os.environ["CREATE_HTTP_CODE"] or None,
    "delete_http_code": os.environ["DELETE_HTTP_CODE"] or None,
    "error_snippet": os.environ["ERROR_SNIPPET"] or None,
    "note": "temporary Paperless tag create-delete probe",
}, indent=2))
PY
  else
    echo "integration: paperless"
    echo "status: $STATUS"
    echo "proven: $PROVEN"
    echo "base_url: ${BASE_URL:-n/a}"
    echo "resolved_host: ${RESOLVED_HOST:-n/a}"
    echo "path_used: ${PATH_USED:-n/a}"
    echo "tag_name: $TAG_NAME"
    echo "tag_id: ${TAG_ID:-n/a}"
    echo "create_http_code: ${CREATE_HTTP_CODE:-n/a}"
    echo "delete_http_code: ${DELETE_HTTP_CODE:-n/a}"
    echo "reason: ${REASON:-temporary Paperless tag create-delete probe}"
    [[ -n "$ERROR_SNIPPET" ]] && echo "error: $ERROR_SNIPPET"
  fi
  exit "$RC"
}

cleanup_tag() {
  local token="$1"
  [[ "$CREATED" -eq 1 && -n "$TAG_ID" && -n "$BASE_URL" ]] || return 0
  curl -sS -o /dev/null \
    -X DELETE \
    -H "Authorization: Token ${token}" \
    "${BASE_URL}/api/tags/${TAG_ID}/" >/dev/null 2>&1 || true
}

trap 'cleanup_tag "${PAPERLESS_TOKEN:-}"' EXIT

command -v curl >/dev/null 2>&1 || { STATUS="stop"; REASON="missing dependency: curl"; RC=2; finish; }
command -v python3 >/dev/null 2>&1 || { STATUS="stop"; REASON="missing dependency: python3"; RC=2; finish; }

PAPERLESS_TOKEN="${PAPERLESS_API_TOKEN:-}"
if [[ -z "$PAPERLESS_TOKEN" && -x "$INFISICAL_AGENT" ]]; then
  PAPERLESS_TOKEN="$("$INFISICAL_AGENT" get infrastructure prod PAPERLESS_API_TOKEN 2>/dev/null || true)"
fi
[[ -n "$PAPERLESS_TOKEN" ]] || { STATUS="stop"; REASON="missing PAPERLESS_API_TOKEN"; RC=2; finish; }

if [[ -n "${PAPERLESS_URL:-}" ]]; then
  BASE_URL="${PAPERLESS_URL%/}"
  PATH_USED="env"
else
  _resolve_result="$(ssh_resolve_host_with_fallback "finance-stack" 2)" || true
  RESOLVED_HOST="$(echo "$_resolve_result" | awk '{print $1}')"
  PATH_USED="$(echo "$_resolve_result" | awk '{print $2}')"
  [[ -z "$RESOLVED_HOST" ]] && RESOLVED_HOST="100.76.153.100"
  [[ -z "$PATH_USED" ]] && PATH_USED="fallback"
  BASE_URL="http://${RESOLVED_HOST}:8000"
fi

create_payload="$(TAG_NAME="$TAG_NAME" python3 - <<'PY'
import json, os
print(json.dumps({"name": os.environ["TAG_NAME"]}))
PY
)"

create_body="$(mktemp)"
create_err="$(mktemp)"
if ! CREATE_HTTP_CODE="$(curl -sS -o "$create_body" -w '%{http_code}' \
  -X POST \
  -H "Authorization: Token ${PAPERLESS_TOKEN}" \
  -H "Content-Type: application/json" \
  -d "$create_payload" \
  "${BASE_URL}/api/tags/" \
  2>"$create_err")"; then
  STATUS="fail"
  REASON="Paperless tag create request failed"
  ERROR_SNIPPET="$(tr '\n' ' ' <"$create_err" | cut -c1-240)"
  finish
fi

if [[ "$CREATE_HTTP_CODE" != "201" && "$CREATE_HTTP_CODE" != "200" ]]; then
  STATUS="fail"
  REASON="Paperless tag create returned non-2xx"
  ERROR_SNIPPET="$(tr -d '\n' <"$create_body" | cut -c1-240)"
  finish
fi

TAG_ID="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get("id",""))' "$create_body" 2>/dev/null || true)"
[[ -n "$TAG_ID" ]] || { STATUS="fail"; REASON="Paperless create response missing tag id"; ERROR_SNIPPET="$(tr -d '\n' <"$create_body" | cut -c1-240)"; finish; }
CREATED=1

delete_body="$(mktemp)"
delete_err="$(mktemp)"
if ! DELETE_HTTP_CODE="$(curl -sS -o "$delete_body" -w '%{http_code}' \
  -X DELETE \
  -H "Authorization: Token ${PAPERLESS_TOKEN}" \
  "${BASE_URL}/api/tags/${TAG_ID}/" \
  2>"$delete_err")"; then
  STATUS="fail"
  REASON="Paperless tag delete request failed"
  ERROR_SNIPPET="$(tr '\n' ' ' <"$delete_err" | cut -c1-240)"
  finish
fi

if [[ "$DELETE_HTTP_CODE" != "204" && "$DELETE_HTTP_CODE" != "200" ]]; then
  STATUS="fail"
  REASON="Paperless tag delete returned non-2xx"
  ERROR_SNIPPET="$(tr -d '\n' <"$delete_body" | cut -c1-240)"
  finish
fi

CREATED=0
STATUS="pass"
PROVEN=true
RC=0
REASON="temporary Paperless tag create-delete probe"
finish
