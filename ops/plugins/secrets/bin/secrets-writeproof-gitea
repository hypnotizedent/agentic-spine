#!/usr/bin/env bash
set -euo pipefail

ROOT="${SPINE_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)}"
SECRETS_EXEC="$ROOT/ops/plugins/secrets/bin/secrets-exec"
source "$ROOT/ops/lib/ssh-resolve.sh"

if [[ -z "${SPINE_SECRETS_INJECTED:-}" ]]; then
  export SPINE_SECRETS_INJECTED=1
  exec "$SECRETS_EXEC" -- "$0" "$@"
fi

JSON_OUT=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) JSON_OUT=1; shift ;;
    --) shift ;;
    *) shift ;;
  esac
done

STATUS="fail"
REASON=""
RC=1
PROVEN=false
AUTH_HTTP_CODE=""
CREATE_HTTP_CODE=""
DELETE_HTTP_CODE=""
ERROR_SNIPPET=""
OWNER=""
API_URL=""
RESOLVED_HOST=""
PATH_USED=""
REPO_NAME="spine-writeproof-$(date -u +%Y%m%d%H%M%S)-$$"
CREATED=0

finish() {
  if [[ "$JSON_OUT" -eq 1 ]]; then
    STATUS="$STATUS" \
    REASON="$REASON" \
    PROVEN="$PROVEN" \
    AUTH_HTTP_CODE="$AUTH_HTTP_CODE" \
    CREATE_HTTP_CODE="$CREATE_HTTP_CODE" \
    DELETE_HTTP_CODE="$DELETE_HTTP_CODE" \
    ERROR_SNIPPET="$ERROR_SNIPPET" \
    OWNER="$OWNER" \
    API_URL="$API_URL" \
    REPO_NAME="$REPO_NAME" \
    RESOLVED_HOST="$RESOLVED_HOST" \
    PATH_USED="$PATH_USED" \
    python3 - <<'PY'
import json, os
print(json.dumps({
    "integration": "gitea",
    "proof_mode": "live_safe",
    "status": os.environ["STATUS"],
    "proven": os.environ["PROVEN"].lower() == "true",
    "reason": os.environ["REASON"],
    "auth_http_code": os.environ["AUTH_HTTP_CODE"] or None,
    "create_http_code": os.environ["CREATE_HTTP_CODE"] or None,
    "delete_http_code": os.environ["DELETE_HTTP_CODE"] or None,
    "owner": os.environ["OWNER"] or None,
    "api_url": os.environ["API_URL"] or None,
    "resolved_host": os.environ["RESOLVED_HOST"] or None,
    "path_used": os.environ["PATH_USED"] or None,
    "probe_repo": os.environ["REPO_NAME"],
    "error_snippet": os.environ["ERROR_SNIPPET"] or None,
    "note": "temporary private repo create-delete probe",
}, indent=2))
PY
  else
    echo "integration: gitea"
    echo "status: $STATUS"
    echo "proven: $PROVEN"
    echo "owner: ${OWNER:-n/a}"
    echo "api_url: ${API_URL:-n/a}"
    echo "resolved_host: ${RESOLVED_HOST:-n/a}"
    echo "path_used: ${PATH_USED:-n/a}"
    echo "probe_repo: $REPO_NAME"
    echo "auth_http_code: ${AUTH_HTTP_CODE:-n/a}"
    echo "create_http_code: ${CREATE_HTTP_CODE:-n/a}"
    echo "delete_http_code: ${DELETE_HTTP_CODE:-n/a}"
    echo "reason: ${REASON:-temporary private repo create-delete probe}"
    [[ -n "$ERROR_SNIPPET" ]] && echo "error: $ERROR_SNIPPET"
  fi
  exit "$RC"
}

cleanup_created_repo() {
  if [[ "$CREATED" -eq 1 && -n "${GITEA_API_TOKEN:-${GITEA_TOKEN:-}}" && -n "$OWNER" && -n "$API_URL" ]]; then
    curl -sS -o /dev/null -X DELETE \
      -H "Authorization: token ${GITEA_API_TOKEN:-${GITEA_TOKEN:-}}" \
      "${API_URL}/api/v1/repos/${OWNER}/${REPO_NAME}" >/dev/null 2>&1 || true
  fi
}
trap cleanup_created_repo EXIT

command -v curl >/dev/null 2>&1 || { STATUS="stop"; REASON="missing dependency: curl"; RC=2; finish; }
command -v python3 >/dev/null 2>&1 || { STATUS="stop"; REASON="missing dependency: python3"; RC=2; finish; }

TOKEN="${GITEA_API_TOKEN:-${GITEA_TOKEN:-}}"
[[ -n "$TOKEN" ]] || { STATUS="stop"; REASON="missing GITEA_API_TOKEN"; RC=2; finish; }

_resolve_result="$(ssh_resolve_host_with_fallback "dev-tools" 2)" || true
RESOLVED_HOST="$(echo "$_resolve_result" | awk '{print $1}')"
PATH_USED="$(echo "$_resolve_result" | awk '{print $2}')"
[[ -z "$RESOLVED_HOST" ]] && RESOLVED_HOST="100.90.167.39"
[[ -z "$PATH_USED" ]] && PATH_USED="fallback"
API_URL="${SPINE_GITEA_API_URL:-${GITEA_API_URL:-http://${RESOLVED_HOST}:3000}}"

user_body="$(mktemp)"
auth_err="$(mktemp)"
if ! AUTH_HTTP_CODE="$(curl -sS -o "$user_body" -w '%{http_code}' \
  -H "Authorization: token ${TOKEN}" \
  "${API_URL}/api/v1/user" \
  2>"$auth_err")"; then
  STATUS="fail"
  REASON="failed to query authenticated Gitea user"
  ERROR_SNIPPET="$(tr '\n' ' ' <"$auth_err" | cut -c1-240)"
  finish
fi

if [[ "$AUTH_HTTP_CODE" != "200" ]]; then
  STATUS="fail"
  REASON="authenticated Gitea user lookup returned non-200"
  ERROR_SNIPPET="$(tr -d '\n' <"$user_body" | cut -c1-240)"
  finish
fi

AUTH_LOGIN="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get("login",""))' "$user_body" 2>/dev/null || true)"
[[ -n "$AUTH_LOGIN" ]] || { STATUS="fail"; REASON="Gitea auth user response missing login"; ERROR_SNIPPET="$(tr -d '\n' <"$user_body" | cut -c1-240)"; finish; }

OWNER="${SPINE_GITEA_OWNER:-${GITEA_OWNER:-$AUTH_LOGIN}}"
CREATE_ENDPOINT="${API_URL}/api/v1/user/repos"
if [[ "$OWNER" != "$AUTH_LOGIN" ]]; then
  CREATE_ENDPOINT="${API_URL}/api/v1/orgs/${OWNER}/repos"
fi

payload="$(REPO_NAME="$REPO_NAME" python3 -c 'import json, os; print(json.dumps({"name": os.environ["REPO_NAME"], "private": True, "auto_init": False, "default_branch": "main"}))')"

create_body="$(mktemp)"
create_err="$(mktemp)"
if ! CREATE_HTTP_CODE="$(curl -sS -o "$create_body" -w '%{http_code}' \
  -X POST \
  -H "Authorization: token ${TOKEN}" \
  -H "Content-Type: application/json" \
  -d "$payload" \
  "${CREATE_ENDPOINT}" \
  2>"$create_err")"; then
  STATUS="fail"
  REASON="Gitea repo create request failed"
  ERROR_SNIPPET="$(tr '\n' ' ' <"$create_err" | cut -c1-240)"
  finish
fi

if [[ "$CREATE_HTTP_CODE" != "201" ]]; then
  STATUS="fail"
  REASON="Gitea repo create returned non-201"
  ERROR_SNIPPET="$(tr -d '\n' <"$create_body" | cut -c1-240)"
  finish
fi
CREATED=1

delete_body="$(mktemp)"
delete_err="$(mktemp)"
if ! DELETE_HTTP_CODE="$(curl -sS -o "$delete_body" -w '%{http_code}' \
  -X DELETE \
  -H "Authorization: token ${TOKEN}" \
  "${API_URL}/api/v1/repos/${OWNER}/${REPO_NAME}" \
  2>"$delete_err")"; then
  STATUS="fail"
  REASON="Gitea repo delete request failed"
  ERROR_SNIPPET="$(tr '\n' ' ' <"$delete_err" | cut -c1-240)"
  finish
fi

if [[ "$DELETE_HTTP_CODE" != "204" && "$DELETE_HTTP_CODE" != "200" ]]; then
  STATUS="fail"
  REASON="Gitea repo delete returned non-2xx"
  ERROR_SNIPPET="$(tr -d '\n' <"$delete_body" | cut -c1-240)"
  finish
fi

CREATED=0
STATUS="pass"
PROVEN=true
RC=0
REASON="temporary private repo create-delete probe"
finish
