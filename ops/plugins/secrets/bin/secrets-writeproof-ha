#!/usr/bin/env bash
set -euo pipefail

ROOT="${SPINE_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)}"
SECRETS_EXEC="$ROOT/ops/plugins/secrets/bin/secrets-exec"
INFISICAL_AGENT="$ROOT/ops/tools/infisical-agent.sh"
source "$ROOT/ops/lib/ssh-resolve.sh"

if [[ -z "${SPINE_SECRETS_INJECTED:-}" ]]; then
  export SPINE_SECRETS_INJECTED=1
  exec "$SECRETS_EXEC" -- "$0" "$@"
fi

JSON_OUT=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) JSON_OUT=1; shift ;;
    --) shift ;;
    *) shift ;;
  esac
done

STATUS="fail"
REASON=""
RC=1
PROVEN=false
CREATE_HTTP_CODE=""
DISMISS_HTTP_CODE=""
ERROR_SNIPPET=""
BASE_URL=""
RESOLVED_HOST=""
PATH_USED=""
NOTIFICATION_ID="${HA_WRITEPROOF_NOTIFICATION_ID:-spine_writeproof_probe}"
CREATED=0

finish() {
  if [[ "$JSON_OUT" -eq 1 ]]; then
    STATUS="$STATUS" \
    REASON="$REASON" \
    PROVEN="$PROVEN" \
    CREATE_HTTP_CODE="$CREATE_HTTP_CODE" \
    DISMISS_HTTP_CODE="$DISMISS_HTTP_CODE" \
    ERROR_SNIPPET="$ERROR_SNIPPET" \
    BASE_URL="$BASE_URL" \
    RESOLVED_HOST="$RESOLVED_HOST" \
    PATH_USED="$PATH_USED" \
    NOTIFICATION_ID="$NOTIFICATION_ID" \
    python3 - <<'PY'
import json, os
print(json.dumps({
    "integration": "home_assistant",
    "proof_mode": "live_safe",
    "status": os.environ["STATUS"],
    "proven": os.environ["PROVEN"].lower() == "true",
    "reason": os.environ["REASON"],
    "base_url": os.environ["BASE_URL"] or None,
    "resolved_host": os.environ["RESOLVED_HOST"] or None,
    "path_used": os.environ["PATH_USED"] or None,
    "notification_id": os.environ["NOTIFICATION_ID"],
    "create_http_code": os.environ["CREATE_HTTP_CODE"] or None,
    "dismiss_http_code": os.environ["DISMISS_HTTP_CODE"] or None,
    "error_snippet": os.environ["ERROR_SNIPPET"] or None,
    "note": "persistent_notification create-dismiss probe",
}, indent=2))
PY
  else
    echo "integration: home_assistant"
    echo "status: $STATUS"
    echo "proven: $PROVEN"
    echo "base_url: ${BASE_URL:-n/a}"
    echo "resolved_host: ${RESOLVED_HOST:-n/a}"
    echo "path_used: ${PATH_USED:-n/a}"
    echo "notification_id: $NOTIFICATION_ID"
    echo "create_http_code: ${CREATE_HTTP_CODE:-n/a}"
    echo "dismiss_http_code: ${DISMISS_HTTP_CODE:-n/a}"
    echo "reason: ${REASON:-persistent_notification create-dismiss probe}"
    [[ -n "$ERROR_SNIPPET" ]] && echo "error: $ERROR_SNIPPET"
  fi
  exit "$RC"
}

dismiss_probe() {
  local token="$1"
  [[ -n "$BASE_URL" ]] || return 0
  curl -sS -o /dev/null \
    -X POST \
    -H "Authorization: Bearer ${token}" \
    -H "Content-Type: application/json" \
    -d "{\"notification_id\":\"${NOTIFICATION_ID}\"}" \
    "${BASE_URL}/api/services/persistent_notification/dismiss" >/dev/null 2>&1 || true
}

trap '[[ "$CREATED" -eq 1 ]] && dismiss_probe "${HA_TOKEN:-}"' EXIT

command -v curl >/dev/null 2>&1 || { STATUS="stop"; REASON="missing dependency: curl"; RC=2; finish; }
command -v python3 >/dev/null 2>&1 || { STATUS="stop"; REASON="missing dependency: python3"; RC=2; finish; }

HA_TOKEN="${HA_API_TOKEN:-}"
if [[ -z "$HA_TOKEN" && -x "$INFISICAL_AGENT" ]]; then
  HA_TOKEN="$("$INFISICAL_AGENT" get infrastructure prod HA_API_TOKEN 2>/dev/null || true)"
fi
[[ -n "$HA_TOKEN" ]] || { STATUS="stop"; REASON="missing HA_API_TOKEN"; RC=2; finish; }

if [[ -n "${HA_URL:-}" ]]; then
  BASE_URL="${HA_URL%/}"
  PATH_USED="env"
else
  _resolve_result="$(ssh_resolve_host_with_fallback "ha" 2)" || true
  RESOLVED_HOST="$(echo "$_resolve_result" | awk '{print $1}')"
  PATH_USED="$(echo "$_resolve_result" | awk '{print $2}')"
  [[ -z "$RESOLVED_HOST" ]] && RESOLVED_HOST="100.67.120.1"
  [[ -z "$PATH_USED" ]] && PATH_USED="fallback"
  BASE_URL="http://${RESOLVED_HOST}:8123"
fi

message="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
create_payload="$(MESSAGE="$message" NOTIFICATION_ID="$NOTIFICATION_ID" python3 - <<'PY'
import json, os
print(json.dumps({
    "title": "Spine writeproof",
    "message": f"temporary secrets writeproof probe {os.environ['MESSAGE']}",
    "notification_id": os.environ["NOTIFICATION_ID"],
}))
PY
)"

create_body="$(mktemp)"
create_err="$(mktemp)"
if ! CREATE_HTTP_CODE="$(curl -sS -o "$create_body" -w '%{http_code}' \
  -X POST \
  -H "Authorization: Bearer ${HA_TOKEN}" \
  -H "Content-Type: application/json" \
  -d "$create_payload" \
  "${BASE_URL}/api/services/persistent_notification/create" \
  2>"$create_err")"; then
  STATUS="fail"
  REASON="Home Assistant notification create request failed"
  ERROR_SNIPPET="$(tr '\n' ' ' <"$create_err" | cut -c1-240)"
  finish
fi

if [[ ! "$CREATE_HTTP_CODE" =~ ^2 ]]; then
  STATUS="fail"
  REASON="Home Assistant notification create returned non-2xx"
  ERROR_SNIPPET="$(tr -d '\n' <"$create_body" | cut -c1-240)"
  finish
fi
CREATED=1

dismiss_body="$(mktemp)"
dismiss_err="$(mktemp)"
if ! DISMISS_HTTP_CODE="$(curl -sS -o "$dismiss_body" -w '%{http_code}' \
  -X POST \
  -H "Authorization: Bearer ${HA_TOKEN}" \
  -H "Content-Type: application/json" \
  -d "{\"notification_id\":\"${NOTIFICATION_ID}\"}" \
  "${BASE_URL}/api/services/persistent_notification/dismiss" \
  2>"$dismiss_err")"; then
  STATUS="fail"
  REASON="Home Assistant notification dismiss request failed"
  ERROR_SNIPPET="$(tr '\n' ' ' <"$dismiss_err" | cut -c1-240)"
  finish
fi

if [[ ! "$DISMISS_HTTP_CODE" =~ ^2 ]]; then
  STATUS="fail"
  REASON="Home Assistant notification dismiss returned non-2xx"
  ERROR_SNIPPET="$(tr -d '\n' <"$dismiss_body" | cut -c1-240)"
  finish
fi

CREATED=0
STATUS="pass"
PROVEN=true
RC=0
REASON="persistent_notification create-dismiss probe"
finish
