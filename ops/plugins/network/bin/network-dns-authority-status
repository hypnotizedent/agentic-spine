#!/usr/bin/env bash
set -euo pipefail

# network.dns.authority.status
# Read-only: verify DNS authority stack health on Pi-hole LXC 105.
# Checks Unbound, cloudflared, Pi-hole upstream config, and DNSSEC.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SPINE_ROOT="${SPINE_ROOT:-$(cd "$SCRIPT_DIR/../../../.." && pwd)}"

PIHOLE_HOST="${PIHOLE_HOME_HOST:-100.105.148.96}"
SSH_OPTS="-o ConnectTimeout=15 -o BatchMode=yes -o StrictHostKeyChecking=accept-new"

pass=0
fail=0
total=0

check() {
  local label="$1"
  local result="$2"
  total=$((total + 1))
  if [[ "$result" == "PASS" ]]; then
    echo "  PASS: $label"
    pass=$((pass + 1))
  else
    echo "  FAIL: $label — $3"
    fail=$((fail + 1))
  fi
}

echo "network.dns.authority.status"
echo "target: pihole-home ($PIHOLE_HOST)"
echo

# ── 1. SSH reachability ──────────────────────────────────────────────────
if ! ssh $SSH_OPTS root@"$PIHOLE_HOST" 'echo ok' >/dev/null 2>&1; then
  echo "  FAIL: SSH unreachable at $PIHOLE_HOST"
  echo
  echo "summary: 0/1 checks passed (SSH unreachable)"
  echo "status: FAIL"
  exit 1
fi

# ── 2. Unbound service status ───────────────────────────────────────────
UNBOUND_STATUS="$(ssh $SSH_OPTS root@"$PIHOLE_HOST" 'systemctl is-active unbound 2>/dev/null' || echo 'inactive')"
if [[ "$UNBOUND_STATUS" == "active" ]]; then
  check "unbound service active" "PASS" ""
else
  check "unbound service active" "FAIL" "status=$UNBOUND_STATUS"
fi

# ── 3. Unbound responds to dig on port 5335 ─────────────────────────────
UNBOUND_DIG="$(ssh $SSH_OPTS root@"$PIHOLE_HOST" 'dig @127.0.0.1 -p 5335 cloudflare.com +short +time=5 2>/dev/null' || true)"
if [[ -n "$UNBOUND_DIG" && "$UNBOUND_DIG" != *"timed out"* && "$UNBOUND_DIG" != *"SERVFAIL"* ]]; then
  check "unbound responds on port 5335" "PASS" ""
else
  check "unbound responds on port 5335" "FAIL" "response='$UNBOUND_DIG'"
fi

# ── 4. cloudflared service status ────────────────────────────────────────
CF_STATUS="$(ssh $SSH_OPTS root@"$PIHOLE_HOST" 'systemctl is-active cloudflared-dns 2>/dev/null' || echo 'inactive')"
if [[ "$CF_STATUS" == "active" ]]; then
  check "cloudflared-dns service active" "PASS" ""
else
  check "cloudflared-dns service active" "FAIL" "status=$CF_STATUS"
fi

# ── 5. cloudflared responds on port 5053 ─────────────────────────────────
CF_DIG="$(ssh $SSH_OPTS root@"$PIHOLE_HOST" 'dig @127.0.0.1 -p 5053 cloudflare.com +short +time=5 2>/dev/null' || true)"
if [[ -n "$CF_DIG" && "$CF_DIG" != *"timed out"* && "$CF_DIG" != *"refused"* ]]; then
  check "cloudflared responds on port 5053" "PASS" ""
else
  check "cloudflared responds on port 5053" "FAIL" "response='$CF_DIG'"
fi

# ── 6. Pi-hole upstream points to Unbound ────────────────────────────────
UPSTREAMS="$(ssh $SSH_OPTS root@"$PIHOLE_HOST" 'grep -A6 "upstreams = \[" /etc/pihole/pihole.toml 2>/dev/null' || true)"
if echo "$UPSTREAMS" | grep -q '127.0.0.1#5335'; then
  check "Pi-hole upstream includes Unbound (127.0.0.1#5335)" "PASS" ""
else
  check "Pi-hole upstream includes Unbound (127.0.0.1#5335)" "FAIL" "upstreams do not include Unbound"
fi

# ── 7. Pi-hole upstream does NOT include public DNS ──────────────────────
HAS_PUBLIC="$(echo "$UPSTREAMS" | grep -E '"(1\.1\.1\.1|1\.0\.0\.1|8\.8\.8\.8|8\.8\.4\.4|9\.9\.9\.9)"' || true)"
if [[ -z "$HAS_PUBLIC" ]]; then
  check "Pi-hole upstream has no public DNS servers" "PASS" ""
else
  check "Pi-hole upstream has no public DNS servers" "FAIL" "found public upstream: $HAS_PUBLIC"
fi

# ── 8. DNSSEC validation ────────────────────────────────────────────────
# sigok.verteiltesysteme.net should resolve; sigfail should not
SIGOK="$(ssh $SSH_OPTS root@"$PIHOLE_HOST" 'dig @127.0.0.1 -p 5335 sigok.verteiltesysteme.net +short +time=5 2>/dev/null' || true)"
if [[ -n "$SIGOK" && "$SIGOK" != *"SERVFAIL"* && "$SIGOK" != *"timed out"* ]]; then
  check "DNSSEC sigok resolves" "PASS" ""
else
  check "DNSSEC sigok resolves" "FAIL" "response='$SIGOK'"
fi

# ── 9. Pi-hole FTL running ──────────────────────────────────────────────
FTL_STATUS="$(ssh $SSH_OPTS root@"$PIHOLE_HOST" 'systemctl is-active pihole-FTL 2>/dev/null' || echo 'inactive')"
if [[ "$FTL_STATUS" == "active" ]]; then
  check "pihole-FTL service active" "PASS" ""
else
  check "pihole-FTL service active" "FAIL" "status=$FTL_STATUS"
fi

# ── 10. Full chain test (Pi-hole → Unbound → root) ──────────────────────
CHAIN_DIG="$(ssh $SSH_OPTS root@"$PIHOLE_HOST" 'dig @127.0.0.1 google.com +short +time=5 2>/dev/null' || true)"
if [[ -n "$CHAIN_DIG" && "$CHAIN_DIG" != *"timed out"* && "$CHAIN_DIG" != *"SERVFAIL"* ]]; then
  check "full chain (Pi-hole → Unbound) resolves" "PASS" ""
else
  check "full chain (Pi-hole → Unbound) resolves" "FAIL" "response='$CHAIN_DIG'"
fi

echo
echo "summary: ${pass}/${total} checks passed"
if [[ $fail -gt 0 ]]; then
  echo "status: FAIL"
  exit 1
fi
echo "status: PASS"
