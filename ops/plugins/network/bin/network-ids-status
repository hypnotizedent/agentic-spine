#!/usr/bin/env bash
set -euo pipefail

# network.ids.status
# Read-only: verify IDS/IPS state on home UDR7 via UniFi API through proxmox-home.
# Checks IDS mode, honeypot, enabled networks, and suppress list.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SPINE_ROOT="${SPINE_ROOT:-$(cd "$SCRIPT_DIR/../../../.." && pwd)}"

PVE_HOME_HOST="${PVE_HOME_HOST:-100.103.99.62}"
UDR_ADDR="10.0.0.1"
IPS_OBJ_ID="69890dc331be437ea46bf845"
SSH_OPTS="-o ConnectTimeout=15 -o BatchMode=yes -o StrictHostKeyChecking=accept-new"

pass=0
fail=0
total=0

check() {
  local label="$1"
  local result="$2"
  total=$((total + 1))
  if [[ "$result" == "PASS" ]]; then
    echo "  PASS: $label"
    pass=$((pass + 1))
  else
    echo "  FAIL: $label — $3"
    fail=$((fail + 1))
  fi
}

echo "network.ids.status"
echo "target: UDR7 ($UDR_ADDR) via proxmox-home ($PVE_HOME_HOST)"
echo

# ── 0. SSH reachability ──────────────────────────────────────────────────
if ! ssh $SSH_OPTS root@"$PVE_HOME_HOST" 'echo ok' >/dev/null 2>&1; then
  echo "  FAIL: proxmox-home ($PVE_HOME_HOST) unreachable via SSH"
  echo
  echo "summary: 0/1 checks passed (SSH unreachable)"
  echo "status: FAIL"
  exit 1
fi

# ── Get API key ──────────────────────────────────────────────────────────
UNIFI_KEY=""
if [[ -f "$SPINE_ROOT/ops/tools/infisical-agent.sh" ]]; then
  UNIFI_KEY="$("$SPINE_ROOT/ops/tools/infisical-agent.sh" get-cached infrastructure prod UNIFI_HOME_API_KEY 2>/dev/null || true)"
fi
if [[ -z "$UNIFI_KEY" ]]; then
  echo "  FAIL: unable to retrieve UNIFI_HOME_API_KEY from Infisical"
  echo
  echo "summary: 0/1 checks passed (no API key)"
  echo "status: FAIL"
  exit 1
fi

# ── Fetch IDS/IPS settings ──────────────────────────────────────────────
IPS_JSON="$(ssh $SSH_OPTS root@"$PVE_HOME_HOST" "curl -sk 'https://${UDR_ADDR}/proxy/network/api/s/default/rest/setting/ips/${IPS_OBJ_ID}' -H 'X-API-KEY: ${UNIFI_KEY}'" 2>/dev/null || true)"

if [[ -z "$IPS_JSON" ]] || ! echo "$IPS_JSON" | python3 -c "import sys,json; json.load(sys.stdin)" 2>/dev/null; then
  echo "  FAIL: unable to reach UniFi IPS API"
  echo
  echo "summary: 0/1 checks passed (API unreachable)"
  echo "status: FAIL"
  exit 1
fi

# Extract fields
IPS_MODE="$(echo "$IPS_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin)['data'][0]; print(d.get('ips_mode','unknown'))" 2>/dev/null || echo "unknown")"
HONEYPOT="$(echo "$IPS_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin)['data'][0]; print(str(d.get('honeypot_enabled',False)).lower())" 2>/dev/null || echo "unknown")"
ADV_FILTER="$(echo "$IPS_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin)['data'][0]; print(d.get('advanced_filtering_preference','unknown'))" 2>/dev/null || echo "unknown")"
ENABLED_NETS="$(echo "$IPS_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin)['data'][0]; print(len(d.get('enabled_networks',[])))" 2>/dev/null || echo "0")"
SUPPRESS_ALERTS="$(echo "$IPS_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin)['data'][0]; print(len(d.get('suppression',{}).get('alerts',[])))" 2>/dev/null || echo "0")"
SUPPRESS_WL="$(echo "$IPS_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin)['data'][0]; print(len(d.get('suppression',{}).get('whitelist',[])))" 2>/dev/null || echo "0")"
MEMORY_OPT="$(echo "$IPS_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin)['data'][0]; print(str(d.get('memory_optimized',False)).lower())" 2>/dev/null || echo "unknown")"

echo "  ips_mode: $IPS_MODE"
echo "  advanced_filtering_preference: $ADV_FILTER"
echo "  honeypot_enabled: $HONEYPOT"
echo "  enabled_networks: $ENABLED_NETS"
echo "  memory_optimized: $MEMORY_OPT"
echo "  suppress_alerts: $SUPPRESS_ALERTS"
echo "  suppress_whitelist: $SUPPRESS_WL"
echo

# ── 1. IDS mode enabled ─────────────────────────────────────────────────
if [[ "$IPS_MODE" == "ids" || "$IPS_MODE" == "ips" ]]; then
  check "IDS/IPS mode enabled (mode=$IPS_MODE)" "PASS" ""
else
  check "IDS/IPS mode enabled" "FAIL" "ips_mode=$IPS_MODE (expected ids or ips)"
fi

# ── 2. Advanced filtering = manual ───────────────────────────────────────
if [[ "$ADV_FILTER" == "manual" ]]; then
  check "advanced filtering preference = manual" "PASS" ""
else
  check "advanced filtering preference = manual" "FAIL" "advanced_filtering_preference=$ADV_FILTER"
fi

# ── 3. Honeypot enabled ─────────────────────────────────────────────────
if [[ "$HONEYPOT" == "true" ]]; then
  check "honeypot enabled" "PASS" ""
else
  check "honeypot enabled" "FAIL" "honeypot_enabled=$HONEYPOT"
fi

# ── 4. At least one network enabled for IDS ──────────────────────────────
if [[ "$ENABLED_NETS" -gt 0 ]]; then
  check "IDS covers $ENABLED_NETS networks" "PASS" ""
else
  check "IDS covers at least 1 network" "FAIL" "enabled_networks=$ENABLED_NETS"
fi

# ── 5. Contract exists and is active ─────────────────────────────────────
CONTRACT="$SPINE_ROOT/ops/bindings/network.ids.tuning.contract.yaml"
if [[ -f "$CONTRACT" ]]; then
  CONTRACT_STATUS="$(grep '^status:' "$CONTRACT" 2>/dev/null | awk '{print $2}' || true)"
  if [[ "$CONTRACT_STATUS" == "active" ]]; then
    check "IDS tuning contract exists and status=active" "PASS" ""
  else
    check "IDS tuning contract exists and status=active" "FAIL" "status=$CONTRACT_STATUS"
  fi
else
  check "IDS tuning contract exists and status=active" "FAIL" "file not found"
fi

echo
echo "summary: ${pass}/${total} checks passed"
if [[ $fail -gt 0 ]]; then
  echo "status: FAIL"
  exit 1
fi
echo "status: PASS"
