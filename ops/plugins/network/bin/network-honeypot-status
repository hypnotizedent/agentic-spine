#!/usr/bin/env bash
set -euo pipefail

# network.honeypot.status
# Read-only: verify honeypot deployment state.
# Phase 1 (interim): UniFi built-in honeypot on UDR7.
# Phase 2 (future): Cowrie SSH honeypot on DMZ VLAN host.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SPINE_ROOT="${SPINE_ROOT:-$(cd "$SCRIPT_DIR/../../../.." && pwd)}"

PVE_HOME_HOST="${PVE_HOME_HOST:-100.103.99.62}"
UDR_ADDR="10.0.0.1"
IPS_OBJ_ID="69890dc331be437ea46bf845"
SSH_OPTS="-o ConnectTimeout=15 -o BatchMode=yes -o StrictHostKeyChecking=accept-new"

pass=0
fail=0
total=0

check() {
  local label="$1"
  local result="$2"
  total=$((total + 1))
  if [[ "$result" == "PASS" ]]; then
    echo "  PASS: $label"
    pass=$((pass + 1))
  else
    echo "  FAIL: $label — $3"
    fail=$((fail + 1))
  fi
}

echo "network.honeypot.status"
echo "target: UDR7 ($UDR_ADDR) via proxmox-home ($PVE_HOME_HOST)"
echo

# ── 0. SSH reachability ──────────────────────────────────────────────────
if ! ssh $SSH_OPTS root@"$PVE_HOME_HOST" 'echo ok' >/dev/null 2>&1; then
  echo "  FAIL: proxmox-home ($PVE_HOME_HOST) unreachable via SSH"
  echo
  echo "summary: 0/1 checks passed (SSH unreachable)"
  echo "status: FAIL"
  exit 1
fi

# ── Get API key ──────────────────────────────────────────────────────────
UNIFI_KEY=""
if [[ -f "$SPINE_ROOT/ops/tools/infisical-agent.sh" ]]; then
  UNIFI_KEY="$("$SPINE_ROOT/ops/tools/infisical-agent.sh" get-cached infrastructure prod UNIFI_HOME_API_KEY 2>/dev/null || true)"
fi
if [[ -z "$UNIFI_KEY" ]]; then
  echo "  FAIL: unable to retrieve UNIFI_HOME_API_KEY from Infisical"
  echo
  echo "summary: 0/1 checks passed (no API key)"
  echo "status: FAIL"
  exit 1
fi

# ── Fetch IDS/IPS settings ──────────────────────────────────────────────
IPS_JSON="$(ssh $SSH_OPTS root@"$PVE_HOME_HOST" "curl -sk 'https://${UDR_ADDR}/proxy/network/api/s/default/rest/setting/ips/${IPS_OBJ_ID}' -H 'X-API-KEY: ${UNIFI_KEY}'" 2>/dev/null || true)"

if [[ -z "$IPS_JSON" ]] || ! echo "$IPS_JSON" | python3 -c "import sys,json; json.load(sys.stdin)" 2>/dev/null; then
  echo "  FAIL: unable to reach UniFi IPS API"
  echo
  echo "summary: 0/1 checks passed (API unreachable)"
  echo "status: FAIL"
  exit 1
fi

# Extract honeypot field
HONEYPOT="$(echo "$IPS_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin)['data'][0]; print(str(d.get('honeypot_enabled',False)).lower())" 2>/dev/null || echo "unknown")"

echo "  Phase 1 — UniFi Built-in Honeypot"
echo "  honeypot_enabled: $HONEYPOT"
echo

# ── 1. UniFi built-in honeypot enabled ───────────────────────────────────
if [[ "$HONEYPOT" == "true" ]]; then
  check "UniFi built-in honeypot enabled" "PASS" ""
else
  check "UniFi built-in honeypot enabled" "FAIL" "honeypot_enabled=$HONEYPOT"
fi

# ── 2. DMZ VLAN firewall rules defined in contract ───────────────────────
CONTRACT="$SPINE_ROOT/ops/bindings/network.honeypot.contract.yaml"
if [[ -f "$CONTRACT" ]]; then
  DMZ_RULES="$(grep -c 'DENY\|ALLOW' "$CONTRACT" 2>/dev/null || echo '0')"
  if [[ "$DMZ_RULES" -ge 2 ]]; then
    check "honeypot contract defines DMZ isolation rules ($DMZ_RULES rules)" "PASS" ""
  else
    check "honeypot contract defines DMZ isolation rules" "FAIL" "found $DMZ_RULES rules"
  fi
else
  check "honeypot contract defines DMZ isolation rules" "FAIL" "contract file not found"
fi

# ── 3. DMZ VLAN topology exists in VLAN contract ─────────────────────────
VLAN_CONTRACT="$SPINE_ROOT/ops/bindings/network.vlan.topology.contract.yaml"
if [[ -f "$VLAN_CONTRACT" ]]; then
  HAS_DMZ="$(grep -c 'dmz\|DMZ\|vlan.*50' "$VLAN_CONTRACT" 2>/dev/null || echo '0')"
  if [[ "$HAS_DMZ" -gt 0 ]]; then
    check "DMZ VLAN (ID 50) defined in VLAN topology contract" "PASS" ""
  else
    check "DMZ VLAN (ID 50) defined in VLAN topology contract" "FAIL" "no DMZ references found"
  fi
else
  check "DMZ VLAN (ID 50) defined in VLAN topology contract" "FAIL" "VLAN contract not found"
fi

# ── 4. Contract exists ───────────────────────────────────────────────────
if [[ -f "$CONTRACT" ]]; then
  CONTRACT_STATUS="$(grep '^status:' "$CONTRACT" 2>/dev/null | awk '{print $2}' || true)"
  check "honeypot contract exists (status=$CONTRACT_STATUS)" "PASS" ""
else
  check "honeypot contract exists" "FAIL" "file not found"
fi

# ── Phase 2 — Cowrie (informational only) ────────────────────────────────
echo
echo "  Phase 2 — Cowrie SSH Honeypot"
echo "  status: blocked_runtime_access (DMZ host not yet allocated)"
echo "  blocker: physical switch port reassignment to VLAN 50 required"

echo
echo "summary: ${pass}/${total} checks passed"
if [[ $fail -gt 0 ]]; then
  echo "status: FAIL"
  exit 1
fi
echo "status: PASS"
