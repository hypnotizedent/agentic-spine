#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "lib"))
from provider_orchestration import load_contract, surface_from_tool, surface_status  # noqa: E402


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Show provider orchestration status across managed surfaces.")
    parser.add_argument("--surface", help="Explicit surface ID (spine_engine, claude_code, codex, opencode, claude_desktop)")
    parser.add_argument("--tool", help="Surface tool alias (claude, codex, opencode, spine_engine, claude_desktop)")
    parser.add_argument("--provider", help="Requested provider override")
    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON")
    return parser.parse_args()


def render_text(statuses: list[dict]) -> None:
    print("providers.status")
    for status in statuses:
        print(f"surface: {status['surface']}")
        print(f"  mode: {status['mode']}")
        if status.get("description"):
            print(f"  description: {status['description']}")
        print(f"  selected: {status.get('selected') or 'none'}")
        for candidate in status["candidates"]:
            state = "READY" if candidate["ready"] else "NOT_READY"
            reason = candidate.get("reason")
            extra = f" ({reason})" if reason else ""
            print(f"  - {candidate['id']}: {state}{extra}")
        print("")


def main() -> int:
    args = parse_args()
    contract = load_contract()
    if args.tool:
        surfaces = [surface_from_tool(args.tool)]
    elif args.surface:
        surfaces = [args.surface]
    else:
        surfaces = list((contract.get("surfaces") or {}).keys())

    statuses = [surface_status(contract, surface, args.provider) for surface in surfaces]
    if args.json:
        if len(statuses) == 1:
            print(json.dumps(statuses[0], indent=2, sort_keys=True))
        else:
            print(json.dumps({"surfaces": statuses}, indent=2, sort_keys=True))
    else:
        render_text(statuses)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
